@{
    ViewData["Title"] = "Validación de Cuenta";
    Layout = "_Layout";
}

<div class="d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-lg border-0" style="width: 100%; max-width: 500px; border-radius: 1rem;">
        <div class="card-body p-5 text-center">
            
            @if (!string.IsNullOrEmpty(ViewBag.Exito))
            {
                <div class="mb-4">
                    <i class="fas fa-check-circle text-success" style="font-size: 5rem;"></i>
                </div>
                <h3 class="fw-bold text-dark mb-3">¡Cuenta Activada!</h3>
                <p class="text-muted mb-4">@ViewBag.Exito</p>
                <a asp-action="Login" asp-controller="Auth" class="btn btn-primary btn-lg w-100 rounded-pill fw-semibold">
                    <i class="fas fa-sign-in-alt me-2"></i>Ir al Inicio de Sesión
                </a>
            }
            else if (!string.IsNullOrEmpty(ViewBag.Error))
            {
                <div class="mb-4">
                    <i class="fas fa-exclamation-triangle text-danger" style="font-size: 5rem;"></i>
                </div>
                <h3 class="fw-bold text-dark mb-3">Error de Validación</h3>
                <p class="text-muted mb-4">@ViewBag.Error</p>
                <a asp-action="RegistroEmpresa" asp-controller="Auth" class="btn btn-outline-secondary btn-lg w-100 rounded-pill fw-semibold">
                    <i class="fas fa-building me-2"></i>Volver a Registro
                </a>
            }
            else
            {
                <div class="mb-4">
                    <i class="fas fa-spinner fa-spin text-primary" style="font-size: 5rem;"></i>
                </div>
                <h3 class="fw-bold text-dark mb-3">Procesando...</h3>
                <p class="text-muted">Por favor espera un momento.</p>
            }

        </div>
    </div>
</div>
