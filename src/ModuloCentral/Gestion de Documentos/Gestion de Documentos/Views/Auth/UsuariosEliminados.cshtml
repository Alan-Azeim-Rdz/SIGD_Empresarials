@model List<Usuario>
@using Gestion_de_Documentos.Models
@{
    ViewData["Title"] = "Personal Inactivo";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-12">
            @if (TempData["Exito"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle"></i> @TempData["Exito"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="fw-bold" style="color: var(--jewel-amethyst);">
                        <i class="fas fa-user-slash"></i> Personal Inactivo (Eliminados)
                    </h2>
                </div>
                <a asp-controller="Auth" asp-action="Usuarios" class="btn btn-jewel-primary">
                    <i class="fas fa-users"></i> Volver a Usuarios
                </a>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card card-jewel">
                <div class="card-body">
                    @if (Model.Count == 0)
                    {
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i> No hay personal inactivo o eliminado.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead style="background-color: var(--jewel-amethyst); color: white;">
                                    <tr>
                                        <th>Correo</th>
                                        <th>Nombre</th>
                                        <th>Departamento</th>
                                        <th>Roles Asignados</th>
                                        <th>Fecha Eliminación</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var usuario in Model)
                                    {
                                        var rolesAsignados = usuario.UsuarioRolIdUsuarioNavigations
                                            .Where(ur => ur.Estatus == true)
                                            .Select(ur => ur.IdRolNavigation?.Nombre ?? "Sin nombre")
                                            .ToList();

                                        <tr>
                                            <td>
                                                <strong>@usuario.Correo</strong>
                                            </td>
                                            <td>@usuario.Nombre @usuario.ApellidoP</td>
                                            <td>
                                                @if (usuario.IdDepartamentoNavigation != null)
                                                {
                                                    <span class="badge bg-light text-dark">@usuario.IdDepartamentoNavigation.Nombre</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-light text-dark">Sin departamento</span>
                                                }
                                            </td>
                                            <td>
                                                @if (rolesAsignados.Count == 0)
                                                {
                                                    <span class="text-muted"><em>Sin roles</em></span>
                                                }
                                                else
                                                {
                                                    @foreach (var rol in rolesAsignados)
                                                    {
                                                        <span class="badge bg-success me-1">@rol</span>
                                                    }
                                                }
                                            </td>
                                            <td>@usuario.FechaEliminacion?.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td>
                                                <form asp-controller="Auth" asp-action="ReactivarUsuario" method="post" style="display: inline;"
                                                      onsubmit="return confirm('¿Estás seguro de reactivar a @usuario.Nombre @usuario.ApellidoP?');">
                                                    <input type="hidden" name="id" value="@usuario.Id" />
                                                    <button type="submit" class="btn btn-sm btn-success" title="Reactivar">
                                                        <i class="fas fa-user-check"></i> Reactivar Usuario
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
