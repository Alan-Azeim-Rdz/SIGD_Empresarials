@{
    Layout = null;
    ViewData["Title"] = "Iniciar Sesión";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar Sesión — SIGD Empresarial</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script>
        (function () {
            const savedTheme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-theme', savedTheme);
        })();
    </script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* ─── Responsive ─── */
        @@media (max-width: 1024px) {
            .lp-left { display: none; }
            .lp-right { flex: 1; }
        }
        @@media (max-width: 480px) {
            .lp-right { padding: 1.5rem 1.25rem; }
            .lp-card  { padding: 28px 22px; }
            .lp-trust { flex-wrap: wrap; }
        }
    </style>
</head>
<body class="login-page-v2">

    <div class="lp-orb lp-orb-1"></div>
    <div class="lp-orb lp-orb-2"></div>
    <div class="lp-orb lp-orb-3"></div>
    <div class="lp-vignette"></div>

    <div class="lp-wrap">

        <!-- ═══ COLUMNA IZQUIERDA ═══ -->
        <div class="lp-left">

            <!-- Badge estado -->
            <div class="lp-badge">
                <div class="lp-badge-dot"></div>
                Sistema operativo
            </div>

            <!-- Logo -->
            <div class="lp-brand">
                <div class="lp-shield-wrap">
                    <div class="lp-shield-glow"></div>
                    <svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect width="64" height="64" rx="16" fill="rgba(59,130,246,0.10)" />
                        <path d="M32 10L48 17v14c0 10-7 19-16 22C13 50 8 41 8 31V17L32 10z"
                              fill="none" stroke="url(#sg1)" stroke-width="2" stroke-linejoin="round"/>
                        <path d="M24 32l5 5 10-10" stroke="url(#sg1)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <defs>
                            <linearGradient id="sg1" x1="8" y1="10" x2="48" y2="54" gradientUnits="userSpaceOnUse">
                                <stop stop-color="#3B82F6"/>
                                <stop offset="1" stop-color="#06B6D4"/>
                            </linearGradient>
                        </defs>
                    </svg>
                </div>
                <div class="lp-brand-text">
                    <div class="lp-brand-name">SIGD</div>
                    <div class="lp-brand-sub">Empresarial</div>
                </div>
            </div>

            <!-- Tagline -->
            <p class="lp-tagline">
                Sistema Integral de Gestión Documental.<br>
                Control total sobre tus documentos corporativos.
            </p>

            <!-- Window mockup -->
            <div class="lp-window">
                <div class="lp-window-bar">
                    <div class="lp-dot lp-dot-r"></div>
                    <div class="lp-dot lp-dot-y"></div>
                    <div class="lp-dot lp-dot-g"></div>
                    <div class="lp-window-url">sigd.empresa.com/documentos</div>
                </div>
                <div class="lp-window-body">
                    <div class="lp-log-line">
                        <span class="lp-log-time">12:41</span>
                        <span class="lp-log-badge lp-log-ok">OK</span>
                        <span class="lp-log-txt">Documento aprobado por Ana M. — Contrato_2026.pdf</span>
                    </div>
                    <div class="lp-log-line">
                        <span class="lp-log-time">12:39</span>
                        <span class="lp-log-badge lp-log-inf">INFO</span>
                        <span class="lp-log-txt">Nueva versión cargada por Carlos R. — v3.1</span>
                    </div>
                    <div class="lp-log-line">
                        <span class="lp-log-time">12:35</span>
                        <span class="lp-log-badge lp-log-wrn">AUDIT</span>
                        <span class="lp-log-txt">Acceso desde IP 10.0.1.42 — usuario jperez</span>
                    </div>
                </div>
            </div>

            <!-- Features 2x2 -->
            <div class="lp-features">
                <div class="lp-feat">
                    <div class="lp-feat-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M9 12h6M9 16h6M9 8h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2h-5L12 2H7a2 2 0 00-2 2v16a2 2 0 002 2z"/>
                        </svg>
                    </div>
                    <div>
                        <div class="lp-feat-title">Control de versiones</div>
                        <div class="lp-feat-desc">Historial completo de cambios</div>
                    </div>
                </div>
                <div class="lp-feat">
                    <div class="lp-feat-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
                        </svg>
                    </div>
                    <div>
                        <div class="lp-feat-title">Flujo de aprobación</div>
                        <div class="lp-feat-desc">Multi-rol y trazable</div>
                    </div>
                </div>
                <div class="lp-feat">
                    <div class="lp-feat-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                        </svg>
                    </div>
                    <div>
                        <div class="lp-feat-title">Auditoría 360°</div>
                        <div class="lp-feat-desc">Cada acción queda registrada</div>
                    </div>
                </div>
                <div class="lp-feat">
                    <div class="lp-feat-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
                        </svg>
                    </div>
                    <div>
                        <div class="lp-feat-title">Búsqueda inteligente</div>
                        <div class="lp-feat-desc">Encuentra todo al instante</div>
                    </div>
                </div>
            </div>

            <!-- Stats -->
            <div class="lp-stats">
                <div class="lp-stat">
                    <div class="lp-stat-num">+500</div>
                    <div class="lp-stat-lbl">Documentos</div>
                </div>
                <div class="lp-stat">
                    <div class="lp-stat-num">99.9%</div>
                    <div class="lp-stat-lbl">Uptime</div>
                </div>
                <div class="lp-stat">
                    <div class="lp-stat-num">24/7</div>
                    <div class="lp-stat-lbl">Disponibilidad</div>
                </div>
            </div>

            <!-- Footer columna -->
            <div class="lp-left-footer">
                v2.0.1 &middot; &copy; 2026 SIGD Empresarial &middot; Powered by .NET 10
            </div>
        </div><!-- /lp-left -->

        <!-- ═══ COLUMNA DERECHA ═══ -->
        <div class="lp-right">
            <div class="lp-card">

                <!-- Header card -->
                <div class="lp-card-header">
                    <div class="lp-lock-wrap">
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0110 0v4"/>
                        </svg>
                    </div>
                    <div class="lp-card-title">Bienvenido de vuelta</div>
                    <div class="lp-card-sub">Inicia sesión para continuar a tu panel</div>
                </div>

                <!-- Exito -->
                @if (TempData["Exito"] != null)
                {
                    <div class="lp-error" style="background-color: rgba(16, 185, 129, 0.1); color: var(--success); border: 1px solid rgba(16, 185, 129, 0.2);">
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="stroke: var(--success);">
                            <path d="M22 11.08V12a10 10 0 11-5.93-9.14"></path>
                            <polyline points="22 4 12 14.01 9 11.01"></polyline>
                        </svg>
                        @TempData["Exito"]
                    </div>
                }

                <!-- Error -->
                @if (ViewBag.Error != null)
                {
                    <div class="lp-error">
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="8" x2="12" y2="12"/>
                            <line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                        @ViewBag.Error
                    </div>
                }

                <!-- Formulario -->
                <form asp-action="Login" method="post">

                    <div class="lp-field">
                        <label class="lp-label" for="username">Username</label>
                        <div class="lp-input-wrap">
                            <svg class="lp-input-icon" viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                                <circle cx="12" cy="7" r="4"/>
                            </svg>
                            <input id="username"
                                   type="text"
                                   name="username"
                                   class="lp-input"
                                   required
                                   placeholder="Ej: admin_sistema"
                                   autocomplete="username" />
                        </div>
                    </div>

                    <div class="lp-field">
                        <label class="lp-label" for="contrasena">Contraseña</label>
                        <div class="lp-input-wrap">
                            <svg class="lp-input-icon" viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                <path d="M7 11V7a5 5 0 0110 0v4"/>
                            </svg>
                            <input id="contrasena"
                                   type="password"
                                   name="contrasena"
                                   class="lp-input lp-input-pw"
                                   required
                                   placeholder="••••••••"
                                   autocomplete="current-password" />
                            <button type="button" class="lp-eye-btn" id="lp-eye-toggle" aria-label="Mostrar contraseña">
                                <svg id="lp-eye-icon" viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                    <circle cx="12" cy="12" r="3"/>
                                </svg>
                            </button>
                        </div>
                    </div>

                    <!-- Remember -->
                    <div class="lp-row-aux" style="justify-content: flex-start;">
                        <label class="lp-remember">
                            <input type="checkbox" name="recordarme" value="true" class="lp-checkbox" />
                            Recuérdame
                        </label>
                    </div>

                    <button type="submit" class="lp-btn">
                        Ingresar
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="5" y1="12" x2="19" y2="12"/>
                            <polyline points="12 5 19 12 12 19"/>
                        </svg>
                    </button>

                    <div style="text-align: center; margin-top: 1rem; margin-bottom: 1rem;">
                        <a href="/Auth/RegistroEmpresa" style="font-size: 0.85rem; color: var(--accent2); text-decoration: none; font-weight: 500; transition: color 0.15s;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--accent2)'">
                            ¿Registrar otra empresa? Regístrate aquí
                        </a>
                    </div>
                </form>

                <!-- Divider -->
                <div class="lp-divider">
                    <div class="lp-divider-line"></div>
                    <span class="lp-divider-txt">Protección activada</span>
                    <div class="lp-divider-line"></div>
                </div>

                <!-- Trust badges -->
                <div class="lp-trust">
                    <div class="lp-trust-badge">
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                        </svg>
                        Conexión cifrada
                    </div>
                    <div class="lp-trust-badge">
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M9 12h6M9 16h6M9 8h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2h-5L12 2H7a2 2 0 00-2 2v16a2 2 0 002 2z"/>
                            <path d="M15 2v4h4"/>
                            <path d="M9 12l2 2 4-4"/>
                        </svg>
                        Acceso registrado
                    </div>
                    <div class="lp-trust-badge">
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="2"/>
                            <path d="M16.24 7.76a6 6 0 010 8.49"/><path d="M7.76 16.24a6 6 0 010-8.49"/>
                            <path d="M20.07 4.93a10 10 0 010 14.14"/><path d="M3.93 19.07a10 10 0 010-14.14"/>
                        </svg>
                        Monitoreo activo
                    </div>
                </div>
            </div>
        </div><!-- /lp-right -->
    </div><!-- /lp-wrap -->

    <script>
        (function () {
            var btn   = document.getElementById('lp-eye-toggle');
            var input = document.getElementById('contrasena');
            var icon  = document.getElementById('lp-eye-icon');

            var eyeOpen   = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
            var eyeClosed = '<path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>';

            if (btn && input && icon) {
                btn.addEventListener('click', function () {
                    var showing = input.type === 'text';
                    input.type = showing ? 'password' : 'text';
                    icon.innerHTML = showing ? eyeOpen : eyeClosed;
                });
            }
        })();
    </script>
</body>
</html>
