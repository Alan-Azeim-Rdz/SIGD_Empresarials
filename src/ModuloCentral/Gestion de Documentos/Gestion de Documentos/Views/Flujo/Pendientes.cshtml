@model IEnumerable<Gestion_de_Documentos.Models.FlujoAprobacion>

@{
    ViewData["Title"] = "Pendientes de Aprobación";
    var total = Model.Count();
}

<div class="page-hero animate-fade-up">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h1><i class="fas fa-inbox me-2"></i>Bandeja de Aprobaciones</h1>
            <p class="mb-0">Documentos que requieren tu revisión y decisión</p>
        </div>
        @if (total > 0)
        {
            <span class="badge" style="background: var(--amber); color: #fff; font-size: 1rem; padding: .5rem 1.1rem; border-radius: 2rem;">
                <i class="fas fa-bell me-1"></i>@total Pendiente@(total != 1 ? "s" : "")
            </span>
        }
    </div>
</div>

@if (!Model.Any())
{
    <div class="card card-jewel text-center py-5 animate-fade-in">
        <div class="card-body">
            <div class="mx-auto mb-3 d-flex align-items-center justify-content-center rounded-xl"
                 style="width:72px;height:72px;background:rgba(15,122,114,.1);">
                <i class="fas fa-check-circle fa-2x" style="color:var(--emerald);"></i>
            </div>
            <h4>¡Todo al día!</h4>
            <p class="text-muted">No tienes documentos pendientes de aprobación. Excelente trabajo.</p>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var flujo in Model)
        {
            var doc = flujo.IdVersionDocumentoNavigation?.IdDocumentoNavigation;
            var ver = flujo.IdVersionDocumentoNavigation;
            <div class="col-md-6 animate-fade-up">
                <div class="card card-jewel h-100">
                    <div class="card-body p-4">

                        <!-- Encabezado del documento -->
                        <div class="d-flex align-items-start gap-3 mb-3">
                            <div class="d-flex align-items-center justify-content-center rounded-xl flex-shrink-0"
                                 style="width:44px;height:44px;background:rgba(30,61,89,.08);">
                                <i class="fas fa-file-pdf" style="color:var(--sapphire);font-size:1.1rem;"></i>
                            </div>
                            <div class="flex-grow-1">
                                <h5 class="mb-1" style="font-size: .98rem; color: var(--sapphire);">
                                    @doc?.Titulo
                                </h5>
                                <code style="font-size: .78rem; color: var(--text-muted);">
                                    @doc?.CodigoInterno
                                </code>
                            </div>
                            <span class="badge badge-revision">
                                <i class="fas fa-clock me-1"></i>En Revisión
                            </span>
                        </div>

                        <!-- Metadatos -->
                        <div class="p-3 mb-3 rounded-xl" style="background: var(--bg-hover); font-size: .83rem;">
                            <div class="d-flex gap-3 flex-wrap">
                                <div>
                                    <span class="text-muted">Versión</span><br>
                                    <strong>V@(ver?.NumeroVersion).@(ver?.VersionMinor)</strong>
                                </div>
                                <div>
                                    <span class="text-muted">Enviado por</span><br>
                                    <strong>Usuario #@flujo.IdUsuarioCreacion</strong>
                                </div>
                                <div>
                                    <span class="text-muted">Fecha</span><br>
                                    <strong>@flujo.FechaCreacion?.ToString("dd/MM/yyyy HH:mm")</strong>
                                </div>
                                <div>
                                    <span class="text-muted">Origen (IP)</span><br>
                                    <strong>@(string.IsNullOrEmpty(flujo.IpOrigenRemitente) ? "Desconocida" : flujo.IpOrigenRemitente)</strong>
                                </div>
                            </div>
                        </div>

                        <!-- Botón revisar -->
                        <div class="d-flex gap-2 mb-3">
                            <a asp-controller="Documento" asp-action="Detalle"
                               asp-route-id="@doc?.Id"
                               class="btn btn-outline-jewel btn-sm w-50">
                                <i class="fas fa-info-circle me-1"></i>Ver Detalles
                            </a>
                            <button type="button" 
                                    class="btn btn-jewel-secondary btn-sm w-50 btn-abrir-visor"
                                    data-version-id="@ver?.Id"
                                    data-flujo-id="@flujo.Id"
                                    data-doc-titulo="@doc?.Titulo"
                                    data-doc-codigo="@doc?.CodigoInterno"
                                    data-src="@Url.Action("VerPrevio", "Documento", new { versionId = ver?.Id })"
                                    data-bs-toggle="modal" data-bs-target="#modalVisorPdf">
                                <i class="fas fa-file-pdf me-1"></i>Previsualizar PDF
                            </button>
                        </div>

                        <!-- Formulario de respuesta -->
                        <form asp-action="Responder" method="post" id="formAprobacion-@flujo.Id">
                            <input type="hidden" name="idFlujo" value="@flujo.Id" />

                            <div class="mb-2">
                                <label class="form-label" style="font-size: .82rem;">Comentarios (Obligatorio para rechazar/aprobar)</label>
                                <textarea name="comentarios" class="form-control" rows="2"
                                          placeholder="Añade tus observaciones aquí..."
                                          style="font-size: .85rem; resize: none;" required></textarea>
                            </div>

                            @if (flujo.TipoAccion == "Revisión")
                            {
                                <div class="mb-3">
                                    <label class="form-label text-secondary fw-bold" style="font-size: .82rem;">Asignar Superior para Firma (Requerido al Aprobar)</label>
                                    <select name="idSuperior" class="form-select select-superior" style="font-size: .85rem;">
                                        <option value="">-- Selecciona a un Superior o Administrador --</option>
                                        @{
                                            var map = ViewBag.SuperiorsMap as Dictionary<int, List<Usuario>>;
                                            if (map != null && map.ContainsKey(flujo.Id))
                                            {
                                                foreach (var sup in map[flujo.Id])
                                                {
                                                    <option value="@sup.Id">@sup.Nombre @sup.ApellidoP</option>
                                                }
                                            }
                                        }
                                    </select>
                                </div>
                            }
                            
                            <div class="form-check mb-3">
                                <input class="form-check-input check-leido" type="checkbox" id="checkLeido-@flujo.Id" data-target="btnGroup-@flujo.Id" disabled>
                                <label class="form-check-label text-muted" for="checkLeido-@flujo.Id" style="font-size: 0.85rem;" id="labelLeido-@flujo.Id">
                                    <i class="fas fa-lock me-1"></i> Debe previsualizar el PDF para firmar.
                                </label>
                            </div>

                            <div class="d-flex gap-2" id="btnGroup-@flujo.Id">
                                <button type="submit" name="respuesta" value="Rechazar"
                                        class="btn btn-sm w-50 btn-action" disabled
                                        style="background: rgba(192,57,43,.1); color: var(--crimson); border: 1px solid rgba(192,57,43,.25); font-weight: 600;">
                                    <i class="fas fa-times me-1"></i>Rechazar
                                </button>
                                <button type="submit" name="respuesta" value="Aprobar"
                                        class="btn btn-jewel-primary btn-sm w-50 btn-action" disabled>
                                    <i class="fas fa-check me-1"></i>Aprobar
                                </button>
                            </div>
                        </form>

                    </div>
                </div>
            </div>
        }
    </div>
}

<!-- Modal Visor PDF Único -->
<div class="modal fade" id="modalVisorPdf" tabindex="-1" aria-labelledby="modalVisorLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered" style="max-width:92vw;">
        <div class="modal-content" style="height:90vh;">
            <div class="modal-header" style="background:var(--bg-card); border-bottom:1px solid var(--border);">
                <div class="d-flex align-items-center gap-2">
                    <i class="fas fa-file-pdf text-danger fs-5"></i>
                    <h5 class="modal-title mb-0" id="modalVisorLabel">Previsualización de Documento</h5>
                    <code id="modalVisorCodigo" class="text-muted ms-2" style="font-size:.78rem;"></code>
                </div>
                <div class="d-flex gap-2 ms-auto me-3">
                    <a id="btnDescargarModal" href="#" class="btn btn-sm btn-outline-success" title="Descargar PDF">
                        <i class="fas fa-download me-1"></i>Descargar
                    </a>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body p-0" style="flex:1; overflow:hidden;">
                <div id="visorLoading" class="d-flex align-items-center justify-content-center h-100"
                     style="background:var(--bg-hover);">
                    <div class="text-center">
                        <div class="spinner-border mb-3" style="color:var(--sapphire); width:3rem; height:3rem;" role="status"></div>
                        <p class="text-muted">Cargando documento...</p>
                    </div>
                </div>
                <iframe id="iframeVisor"
                        src="about:blank"
                        style="width:100%; height:100%; border:none; display:none;"
                        title="Visor de documento PDF">
                </iframe>
            </div>
            <div class="modal-footer" style="background:var(--bg-card); border-top:1px solid var(--border); font-size:.82rem;">
                <span id="estadoVista" class="text-muted me-auto">
                    <i class="fas fa-info-circle me-1"></i>Esperando a que cargue el documento...
                </span>
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">
                    <i class="fas fa-times me-1"></i>Cerrar Visor
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const modal = document.getElementById('modalVisorPdf');
            const iframe = document.getElementById('iframeVisor');
            const loading = document.getElementById('visorLoading');
            const estadoEl = document.getElementById('estadoVista');
            const titleEl = document.getElementById('modalVisorLabel');
            const codeEl = document.getElementById('modalVisorCodigo');
            const downloadBtn = document.getElementById('btnDescargarModal');

            let currentFlujoId = null;
            let currentVersionId = null;

            // Validar selección de Superior antes de Aprobar
            document.querySelectorAll('form[id^="formAprobacion-"]').forEach(form => {
                form.addEventListener('submit', function (e) {
                    const actionButton = document.activeElement;
                    if (actionButton && actionButton.value === 'Aprobar') {
                        const selectSuperior = form.querySelector('.select-superior');
                        if (selectSuperior && !selectSuperior.value) {
                            e.preventDefault();
                            alert('Debe seleccionar un Superior o Administrador para enviar a firma.');
                        }
                    }
                });
            });

            function registrarLectura() {
                if (iframe.src === 'about:blank' || !currentVersionId) return;

                loading.classList.add('d-none');
                loading.classList.remove('d-flex');
                iframe.style.display = 'block';

                // Registrar la vista en sesión en el servidor
                fetch('@Url.Action("RegistrarVista", "Documento")?versionId=' + currentVersionId, {
                    method: 'POST',
                    headers: { 
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || '' 
                    }
                })
                .then(res => {
                    if (res.ok) {
                        estadoEl.innerHTML = '<i class="fas fa-check-circle me-1 text-success"></i>Documento leído — ya puede cerrar esta ventana y firmar.';
                        estadoEl.className = 'text-success me-auto fw-semibold';

                        // Habilitar y marcar el checkbox correspondiente
                        const chk = document.getElementById('checkLeido-' + currentFlujoId);
                        const lbl = document.getElementById('labelLeido-' + currentFlujoId);
                        if (chk) {
                            chk.disabled = false;
                            chk.checked = true;
                            
                            // Cambiar la etiqueta a una verde indicando que fue previsualizado
                            if (lbl) {
                                lbl.innerHTML = '<i class="fas fa-check-circle text-success me-1"></i> Documento previsualizado y verificado.';
                                lbl.className = 'form-check-label text-success fw-semibold';
                            }

                            // Habilitar los botones
                            const btnGroup = document.getElementById('btnGroup-' + currentFlujoId);
                            if (btnGroup) {
                                const buttons = btnGroup.querySelectorAll('.btn-action');
                                buttons.forEach(btn => {
                                    btn.disabled = false;
                                });
                            }
                        }
                    } else {
                        estadoEl.innerHTML = '<i class="fas fa-exclamation-triangle me-1 text-warning"></i> Error al registrar la previsualización.';
                        estadoEl.className = 'text-warning me-auto';
                    }
                })
                .catch(() => {
                    estadoEl.innerHTML = '<i class="fas fa-exclamation-triangle me-1 text-warning"></i> Error de red al registrar la previsualización.';
                    estadoEl.className = 'text-warning me-auto';
                });
            }

            // Al hacer clic en un botón de previsualizar, configurar el modal
            const btnsAbrir = document.querySelectorAll('.btn-abrir-visor');
            btnsAbrir.forEach(btn => {
                btn.addEventListener('click', function () {
                    const src = this.dataset.src;
                    currentFlujoId = this.dataset.flujoId;
                    currentVersionId = this.dataset.versionId;
                    
                    titleEl.textContent = this.dataset.docTitulo;
                    codeEl.textContent = this.dataset.docCodigo;
                    downloadBtn.href = '@Url.Action("Descargar", "Documento")?versionId=' + currentVersionId;

                    loading.classList.remove('d-none');
                    loading.classList.add('d-flex');
                    iframe.style.display = 'none';
                    iframe.src = src;

                    estadoEl.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Cargando documento...';
                    estadoEl.className = 'text-muted me-auto';

                    // Fallback para navegadores que no disparan el evento 'load' en PDFs
                    setTimeout(function() {
                        if (!loading.classList.contains('d-none')) {
                            registrarLectura();
                        }
                    }, 1500);
                });
            });

            // Cuando el iframe carga
            iframe.addEventListener('load', function() {
                if (!loading.classList.contains('d-none')) {
                    registrarLectura();
                }
            });

            // Limpiar al cerrar modal
            if (modal) {
                modal.addEventListener('hidden.bs.modal', function () {
                    iframe.src = 'about:blank';
                    loading.classList.remove('d-none');
                    loading.classList.add('d-flex');
                    iframe.style.display = 'none';
                });
            }
        });
    </script>
}
