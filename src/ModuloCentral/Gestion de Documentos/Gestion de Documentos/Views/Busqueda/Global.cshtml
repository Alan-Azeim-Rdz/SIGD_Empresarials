@{
    ViewData["Title"] = "Buscador Global de Documentos";
}

<style>
    /* ── Buscador Hero ── */
    .search-input-group {
        border-radius: 2rem;
        overflow: hidden;
        background-color: #fff;
        border: 1px solid var(--border);
        transition: border-color .2s, box-shadow .2s;
    }
    .search-input-group:focus-within {
        border-color: var(--border-focus);
        box-shadow: 0 0 0 3px rgba(45,106,159,.18);
    }
    #search-input {
        border: none;
        outline: none;
        box-shadow: none !important;
    }

    /* ── Meta info conectividad ── */
    .connectivity-badge {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.2);
        border-radius: 2rem;
        padding: .25rem .85rem;
        font-size: .75rem;
        color: rgba(255,255,255,.9);
    }
    .connectivity-badge .dot {
        width: 7px; height: 7px;
        border-radius: 50%;
        background: #4ade80;
        animation: pulse-ring 1.8s infinite;
    }
    .connectivity-badge.offline .dot { background: #f87171; animation: none; }

    /* ── Spinner ── */
    #spinner { display: none; }

    /* ── Stats bar ── */
    #results-header { display: none; }
    .results-stats {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: .5rem;
        padding: .75rem 0;
        border-bottom: 1px solid var(--border);
        margin-bottom: 1.25rem;
    }
    .results-stats .count {
        font-weight: 700;
        color: var(--text-primary);
        font-size: .95rem;
    }
    .results-stats .source-badge {
        background: rgba(107,76,154,.1);
        color: var(--amethyst);
        border: 1px solid rgba(107,76,154,.2);
        border-radius: 2rem;
        padding: .2rem .8rem;
        font-size: .75rem;
        font-weight: 600;
    }

    /* ── Tarjetas de resultado ── */
    .result-card {
        border: 1px solid var(--border) !important;
        border-radius: var(--radius-md) !important;
        box-shadow: var(--shadow-sm) !important;
        margin-bottom: .85rem;
        transition: all .2s var(--ease) !important;
        animation: fadeInUp .3s var(--ease) both;
        border-left: 4px solid transparent !important;
    }
    .result-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-md) !important;
        border-left: 4px solid var(--emerald) !important;
    }
    .result-card .card-body { padding: 1.15rem 1.25rem; }

    .result-title {
        font-size: 1rem;
        font-weight: 700;
        color: var(--sapphire);
        margin-bottom: .2rem;
    }
    .result-code {
        font-size: .78rem;
        color: var(--text-muted);
        font-family: 'Courier New', monospace;
    }
    .result-score {
        background: rgba(30,61,89,.08);
        color: var(--sapphire);
        border-radius: 2rem;
        padding: .2rem .7rem;
        font-size: .72rem;
        font-weight: 700;
        white-space: nowrap;
    }
    .result-tag {
        display: inline-block;
        background: rgba(15,122,114,.1);
        color: var(--emerald-dark);
        border: 1px solid rgba(15,122,114,.2);
        border-radius: 2rem;
        padding: .15rem .6rem;
        font-size: .72rem;
        font-weight: 500;
        margin-right: .3rem;
        margin-top: .3rem;
    }
    .result-extract {
        font-size: .88rem;
        color: var(--text-secondary);
        margin-top: .6rem;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.55;
    }
    .result-footer {
        margin-top: .85rem;
        padding-top: .75rem;
        border-top: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: .5rem;
    }
    .result-meta { font-size: .75rem; color: var(--text-muted); }

    /* ── Estados vacíos ── */
    #no-results, #error-msg { display: none; }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
    }
    .empty-state .icon-circle {
        width: 80px; height: 80px;
        border-radius: 50%;
        background: rgba(30,61,89,.08);
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 1.25rem;
        font-size: 2rem;
        color: var(--sapphire);
    }
    .empty-state h4 { font-size: 1.1rem; color: var(--text-primary); }
    .empty-state p  { color: var(--text-muted); font-size: .9rem; }

    /* ── Tip de búsqueda ── */
    .search-tip {
        background: rgba(107,76,154,.06);
        border: 1px solid rgba(107,76,154,.15);
        border-radius: var(--radius-md);
        padding: 1rem 1.25rem;
        margin-top: 1.5rem;
    }
    .search-tip .tip-title {
        font-size: .8rem;
        font-weight: 700;
        color: var(--amethyst);
        text-transform: uppercase;
        letter-spacing: .04em;
        margin-bottom: .5rem;
    }
    .search-tip ul {
        margin: 0; padding-left: 1.1rem;
        font-size: .83rem;
        color: var(--text-secondary);
    }
    .search-tip ul li { margin-bottom: .25rem; }
</style>

<!-- Hero con buscador -->
<div class="page-hero animate-fade-in mb-4">
    <h1><i class="fas fa-search me-2"></i>Buscador Global de Documentos</h1>
    <p class="mb-4">Busca en todos los documentos vigentes del sistema de forma instantánea — impulsado por MongoDB</p>

    <div class="input-group search-input-group shadow-sm">
        <span class="input-group-text bg-white border-end-0 px-3" style="border-radius: 2rem 0 0 2rem;"><i class="fas fa-search text-muted"></i></span>
        <input id="search-input"
               type="text"
               class="form-control border-start-0 ps-1"
               style="border-radius: 0; padding: .85rem 1rem; border: none; font-size: 0.95rem;"
               placeholder="Escribe el título, código, etiquetas o palabras clave…"
               maxlength="100"
               autocomplete="off"
               aria-label="Término de búsqueda" />
        <button id="btn-buscar" class="btn btn-jewel-primary px-4 fw-bold" style="border-radius: 0 2rem 2rem 0; font-size: 0.95rem; border: none;" aria-label="Buscar">
            Buscar
        </button>
    </div>

    <div id="connectivity-indicator" class="connectivity-badge offline mt-3">
        <span class="dot"></span>
        <span id="connectivity-text">Verificando conexión con Motor de Búsqueda…</span>
    </div>
</div>

<!-- Spinner de carga -->
<div id="spinner" class="text-center my-5">
    <div class="spinner-border" role="status" style="width:3rem;height:3rem;"></div>
    <p class="mt-3 fw-semibold" style="color: var(--text-secondary);">Consultando índice MongoDB…</p>
</div>

<!-- Sin resultados -->
<div id="no-results" class="empty-state animate-fade-in">
    <div class="icon-circle"><i class="fas fa-folder-open"></i></div>
    <h4>Sin resultados para <strong id="term-label"></strong></h4>
    <p>Verifica que el documento exista y esté en estado <strong>Vigente</strong>, o intenta con otras palabras clave.</p>
</div>

<!-- Error -->
<div id="error-msg" class="alert alert-danger animate-fade-in" role="alert">
    <i class="fas fa-exclamation-triangle me-2"></i>
    <span id="error-text"></span>
</div>

<!-- Header de resultados -->
<div id="results-header" class="results-stats">
    <span class="count" id="results-count"></span>
    <span class="source-badge"><i class="fas fa-database me-1"></i>Índice MongoDB · Node.js/TypeScript</span>
</div>

<!-- Tarjetas de resultado -->
<div id="results-container"></div>

<!-- Tip inicial -->
<div id="search-tip-initial" class="search-tip">
    <div class="tip-title"><i class="fas fa-lightbulb me-1"></i>Consejos de búsqueda</div>
    <ul>
        <li>Escribe el <strong>título</strong> o parte del código interno (ej. <code>CAL-MAN</code>)</li>
        <li>Busca por <strong>etiquetas</strong>: calidad, ISO, procedimiento, manual…</li>
        <li>El buscador es insensible a mayúsculas y busca en título, tags y contenido</li>
        <li>Solo devuelve documentos con estado <strong>Vigente</strong></li>
    </ul>
</div>

@section Scripts {
<script>
(function () {
    const input     = document.getElementById('search-input');
    const btnBuscar = document.getElementById('btn-buscar');
    const spinner   = document.getElementById('spinner');
    const noResults = document.getElementById('no-results');
    const errorMsg  = document.getElementById('error-msg');
    const errorText = document.getElementById('error-text');
    const container = document.getElementById('results-container');
    const header    = document.getElementById('results-header');
    const countEl   = document.getElementById('results-count');
    const termLabel = document.getElementById('term-label');
    const tipInit   = document.getElementById('search-tip-initial');
    const connBadge = document.getElementById('connectivity-indicator');
    const connText  = document.getElementById('connectivity-text');

    // ── Health check al módulo TypeScript via proxy C# ────────────────
    async function checkConnectivity() {
        try {
            const resp = await fetch('/Busqueda/Buscar?q=health');
            // Cualquier respuesta (incluso 400 por query vacío) indica que el proxy funciona
            if (resp.ok || resp.status === 400) {
                connBadge.classList.remove('offline');
                connText.textContent = 'Motor de búsqueda activo · MongoDB + TypeScript';
            } else {
                connBadge.classList.add('offline');
                connText.textContent = 'Motor de búsqueda no disponible';
            }
        } catch {
            connBadge.classList.add('offline');
            connText.textContent = 'Error de conexión con el motor de búsqueda';
        }
    }

    checkConnectivity();

    // ── Reset UI ───────────────────────────────────────────────────────
    function resetUI() {
        spinner.style.display   = 'none';
        noResults.style.display = 'none';
        errorMsg.style.display  = 'none';
        header.style.display    = 'none';
        container.innerHTML     = '';
        tipInit.style.display   = 'none';
    }

    // ── Buscar ─────────────────────────────────────────────────────────
    async function buscar() {
        const q = input.value.trim();
        if (!q) { input.focus(); return; }

        resetUI();
        spinner.style.display = 'block';

        try {
            const resp = await fetch(`/Busqueda/Buscar?q=${encodeURIComponent(q)}`);
            const json = await resp.json();

            spinner.style.display = 'none';

            // ── Manejo de error del proxy ──────────────────────────────────
            if (json.error) {
                errorText.textContent  = json.error;
                errorMsg.style.display = 'block';
                return;
            }

            // ── Compatibilidad: API devuelve { success, total, data: [...] }
            //    El proxy C# pasa el JSON tal cual desde Node.js.
            let resultados = [];
            if (json.success !== undefined) {
                // Respuesta nueva de Node.js: { success, total, data }
                if (!json.success) {
                    errorText.textContent  = json.mensaje || 'Error al procesar la búsqueda.';
                    errorMsg.style.display = 'block';
                    return;
                }
                resultados = Array.isArray(json.data) ? json.data : [];
            } else if (Array.isArray(json)) {
                // Respuesta plana (legado)
                resultados = json;
            }

            // ── Sin resultados ─────────────────────────────────────────────
            if (resultados.length === 0) {
                termLabel.textContent   = `"${q}"`;
                noResults.style.display = 'block';
                return;
            }

            // ── Mostrar resultados ─────────────────────────────────────────
            const n = resultados.length;
            countEl.textContent  = `${n} documento${n !== 1 ? 's' : ''} encontrado${n !== 1 ? 's' : ''} para "${q}"`;
            header.style.display = 'flex';

            resultados.forEach((doc, i) => {
                const tagsHtml = (doc.tags || [])
                    .map(t => `<span class="result-tag">${escapeHtml(t)}</span>`).join('');

                const score = doc.score
                    ? `<span class="result-score"><i class="fas fa-star me-1"></i>Relevancia: ${doc.score.toFixed(2)}</span>`
                    : '';

                const extract = doc.contenido_extraido
                    ? `<p class="result-extract">${escapeHtml(doc.contenido_extraido)}</p>` : '';

                const fechaIdx = doc.fecha_indexacion
                    ? new Date(doc.fecha_indexacion).toLocaleDateString('es-MX', { day: '2-digit', month: 'short', year: 'numeric' })
                    : '';

                const card = `
                    <div class="card result-card" style="animation-delay:${i * 0.06}s">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start gap-2 flex-wrap">
                                <div>
                                    <div class="result-title">${escapeHtml(doc.titulo)}</div>
                                    <span class="result-code">
                                        <i class="fas fa-barcode me-1"></i>${escapeHtml(doc.codigo_interno)}
                                        ${doc.version ? `<span class="ms-2">v${doc.version}</span>` : ''}
                                    </span>
                                </div>
                                ${score}
                            </div>
                            ${tagsHtml ? `<div class="mt-2">${tagsHtml}</div>` : ''}
                            ${extract}
                            <div class="result-footer">
                                <span class="result-meta">
                                    ${fechaIdx ? `<i class="fas fa-calendar-alt me-1"></i>Indexado: ${fechaIdx}` : ''}
                                    ${doc.ip_subida ? `<span class="ms-3 text-muted"><i class="fas fa-network-wired me-1"></i>IP Subida: ${escapeHtml(doc.ip_subida)}</span>` : ''}
                                </span>
                                <a href="/Documento/Detalle/${doc.id_documento_sql}" class="btn btn-sm btn-jewel-secondary">
                                    <i class="fas fa-eye me-1"></i>Ver Detalle
                                </a>
                            </div>
                        </div>
                    </div>`;

                container.insertAdjacentHTML('beforeend', card);
            });

        } catch (err) {
            spinner.style.display  = 'none';
            errorText.textContent  = 'Error inesperado al conectar con el motor de búsqueda. Verifica que el servicio Node.js esté activo.';
            errorMsg.style.display = 'block';
        }
    }

    // ── Escape XSS ────────────────────────────────────────────────────
    function escapeHtml(str) {
        const d = document.createElement('div');
        d.textContent = str ?? '';
        return d.innerHTML;
    }

    // ── Eventos ───────────────────────────────────────────────────────
    btnBuscar.addEventListener('click', buscar);
    input.addEventListener('keydown', e => { if (e.key === 'Enter') buscar(); });

    // Búsqueda automática si viene ?q= en la URL
    const urlQ = new URLSearchParams(window.location.search).get('q');
    if (urlQ) {
        input.value = urlQ;
        buscar();
    }
})();
</script>
}
