@model Gestion_de_Documentos.Models.Documento

@using System.Security.Claims
@{
    ViewData["Title"] = "Historial de Versiones";
    var userIdStr = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    var currentUserId = int.TryParse(userIdStr, out var id) ? id : 0;
    var esAdminOrCreator = Model.IdUsuarioCreacion == currentUserId || User.IsInRole("Administrador") || User.IsInRole("Super Administrador");
}

<div class="card card-jewel mt-4">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h3 class="mb-0 text-dark">Historial de Versiones: @Model.Titulo</h3>
        <a asp-action="Detalle" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm"><i class="fas fa-arrow-left"></i> Volver a Detalles</a>
    </div>
    <div class="card-body">
        
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Versión</th>
                        <th>Fecha de Subida</th>
                        <th>Tamaño</th>
                        <th>Hash (SHA256)</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if(Model.DocumentoVersions != null && Model.DocumentoVersions.Any())
                    {
                        var maxAprobada = Model.DocumentoVersions.Where(v => v.VersionMinor == 0 && v.Estatus == true).Max(v => (int?)v.NumeroVersion) ?? 0;
                        foreach(var version in Model.DocumentoVersions.OrderByDescending(v => v.NumeroVersion).ThenByDescending(v => v.VersionMinor))
                        {
                            var isObsoleto = version.VersionMinor == 0 && version.NumeroVersion > 0 && version.NumeroVersion < maxAprobada;
                            var isVigente = version.VersionMinor == 0 && version.NumeroVersion > 0 && version.NumeroVersion == maxAprobada;
                            <tr>
                                <td>
                                    <span class="badge bg-primary">V @version.NumeroVersion.@version.VersionMinor</span>
                                    @if(isVigente) { <span class="badge bg-success ms-1">Vigente</span> }
                                    @if(isObsoleto) { <span class="badge bg-secondary ms-1">Obsoleto</span> }
                                </td>
                                <td>@version.FechaSubida?.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@(version.TamanoBytes.HasValue ? (version.TamanoBytes.Value / 1024).ToString("N0") + " KB" : "-")</td>
                                <td><small class="text-muted text-break" style="max-width: 200px; display: inline-block;" title="@version.HashDocumento">@version.HashDocumento</small></td>
                                <td>
                                    <a asp-action="Descargar" asp-route-versionId="@version.Id" class="btn btn-sm btn-outline-primary" title="Descargar PDF">
                                        <i class="fas fa-download"></i> Descargar
                                    </a>
                                    @if (esAdminOrCreator)
                                    {
                                        <form asp-action="EliminarVersion" method="post" style="display: inline;" 
                                              onsubmit="return confirm('¿Estás seguro de eliminar esta versión? Esta acción es irreversible para fines de este historial y podría revertir el estado del documento.');">
                                            <input type="hidden" name="versionId" value="@version.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar Versión">
                                                <i class="fas fa-trash-alt"></i> Eliminar
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center">No hay versiones registradas.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
    </div>
</div>
