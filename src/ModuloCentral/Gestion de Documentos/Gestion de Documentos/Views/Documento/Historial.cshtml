@model Gestion_de_Documentos.Models.Documento

@{
    ViewData["Title"] = "Historial de Versiones";
}

<div class="card card-jewel mt-4">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h3 class="mb-0 text-dark">Historial de Versiones: @Model.Titulo</h3>
        <a asp-action="Detalle" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm"><i class="fas fa-arrow-left"></i> Volver a Detalles</a>
    </div>
    <div class="card-body">
        
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Versión</th>
                        <th>Fecha de Subida</th>
                        <th>Tamaño</th>
                        <th>Hash (SHA256)</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if(Model.DocumentoVersions != null && Model.DocumentoVersions.Any())
                    {
                        foreach(var version in Model.DocumentoVersions.OrderByDescending(v => v.NumeroVersion).ThenByDescending(v => v.VersionMinor))
                        {
                            <tr>
                                <td><span class="badge bg-primary">V @version.NumeroVersion.@version.VersionMinor</span></td>
                                <td>@version.FechaSubida?.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@(version.TamanoBytes.HasValue ? (version.TamanoBytes.Value / 1024).ToString("N0") + " KB" : "-")</td>
                                <td><small class="text-muted text-break" style="max-width: 200px; display: inline-block;" title="@version.HashDocumento">@version.HashDocumento</small></td>
                                <td>
                                    <a asp-action="Descargar" asp-route-versionId="@version.Id" class="btn btn-sm btn-outline-primary" title="Descargar PDF">
                                        <i class="fas fa-download"></i> Descargar
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center">No hay versiones registradas.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
    </div>
</div>
