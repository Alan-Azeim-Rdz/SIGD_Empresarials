@model IEnumerable<Gestion_de_Documentos.Models.Documento>

@{
    ViewData["Title"] = "Mis Documentos";
}

<div class="page-hero animate-fade-up">
    <h1><i class="fas fa-folder-open me-2"></i>Mis Documentos</h1>
    <p>Gestiona tus documentos creados, borradores y versiones enviadas para aprobación</p>
</div>

<div class="card card-jewel animate-fade-up" style="animation-delay:.1s">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-2">
            <h3 class="mb-0" style="font-size: 1rem;">
                <i class="fas fa-list me-2" style="color: var(--sapphire);"></i>Listado de Documentos
            </h3>
            <span class="badge" style="background: rgba(30,61,89,.1); color: var(--sapphire);">
                @Model.Count() documentos
            </span>
        </div>
        <a asp-action="Crear" class="btn btn-primary btn-sm">
            <i class="fas fa-plus me-1"></i>Nuevo Documento
        </a>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="fas fa-file-alt fa-3x mb-3" style="color: var(--border);"></i>
                <p class="text-muted">Aún no tienes documentos creados.</p>
                <a asp-action="Crear" class="btn btn-jewel-primary">
                    <i class="fas fa-plus me-1"></i>Crear primer documento
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table mb-0" id="tabla-documentos">
                    <thead>
                        <tr>
                            <th><i class="fas fa-barcode me-1"></i>Código</th>
                            <th><i class="fas fa-heading me-1"></i>Título</th>
                            <th>Versión</th>
                            <th>Tipo</th>
                            <th>Depto.</th>
                            <th>Estado</th>
                            <th><i class="fas fa-calendar me-1"></i>Fecha</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var ultimaV = item.DocumentoVersions.OrderByDescending(v => v.NumeroVersion).ThenByDescending(v => v.VersionMinor).FirstOrDefault();
                            var versionStr = ultimaV != null ? $"{ultimaV.NumeroVersion}.{ultimaV.VersionMinor}" : "—";
                            <tr class="animate-fade-in">
                                <td>
                                    <code style="font-size: .8rem; color: var(--sapphire);">@item.CodigoInterno</code>
                                </td>
                                <td class="fw-semibold">@item.Titulo</td>
                                <td><span class="badge bg-primary">V @versionStr</span></td>
                                <td class="text-muted">@item.IdTipoDocumentoNavigation?.Nombre</td>
                                <td class="text-muted">@item.IdDepartamentoNavigation?.Nombre</td>
                                <td>
                                    @if (item.EstadoActual == "Borrador")
                                    {
                                        <span class="badge badge-borrador"><i class="fas fa-pencil-alt me-1"></i>Borrador</span>
                                    }
                                    else if (item.EstadoActual == "En Revision")
                                    {
                                        <span class="badge badge-revision"><i class="fas fa-clock me-1"></i>En Revisión</span>
                                    }
                                    else if (item.EstadoActual == "Vigente")
                                    {
                                        <span class="badge badge-vigente"><i class="fas fa-check me-1"></i>Vigente</span>
                                    }
                                    else if (item.EstadoActual == "Obsoleto")
                                    {
                                        <span class="badge badge-obsoleto"><i class="fas fa-archive me-1"></i>Obsoleto</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-rechaz"><i class="fas fa-times me-1"></i>Rechazado</span>
                                    }
                                    
                                    @{
                                        var ultimoFlujo = ultimaV?.FlujoAprobacions.OrderByDescending(f => f.FechaModificacion).FirstOrDefault();
                                        if (ultimoFlujo != null && !string.IsNullOrEmpty(ultimoFlujo.Comentarios) && (item.EstadoActual == "Rechazado" || item.EstadoActual == "Vigente"))
                                        {
                                            <i class="fas fa-info-circle ms-2" style="color: var(--sapphire); cursor: help;" data-bs-toggle="tooltip" title="@ultimoFlujo.Comentarios"></i>
                                        }
                                    }
                                </td>
                                <td class="text-muted" style="font-size: .82rem;">
                                    @item.FechaCreacion?.ToString("dd/MM/yyyy HH:mm")
                                </td>
                                <td class="text-center">
                                    <a asp-action="Detalle" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-jewel-secondary">
                                        <i class="fas fa-eye me-1"></i>Ver Detalle
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@if (ViewBag.TotalPaginas > 1)
{
    <div class="d-flex justify-content-between align-items-center mt-3 px-3 pb-3">
        <small class="text-muted">
            Mostrando página @ViewBag.PaginaActual de @ViewBag.TotalPaginas
            (@ViewBag.TotalDocs documentos en total)
        </small>
        <nav>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(ViewBag.PaginaActual == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="@(ViewBag.PaginaActual - 1)">
                        <i class="fas fa-chevron-left"></i>
                    </a>
                </li>
                @for (int i = 1; i <= ViewBag.TotalPaginas; i++)
                {
                    <li class="page-item @(i == ViewBag.PaginaActual ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pagina="@i">@i</a>
                    </li>
                }
                <li class="page-item @(ViewBag.PaginaActual == ViewBag.TotalPaginas ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pagina="@(ViewBag.PaginaActual + 1)">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            });
        });
    </script>
}
