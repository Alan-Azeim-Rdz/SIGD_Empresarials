@model Gestion_de_Documentos.Controllers.CrearEmpresaViewModel
@{
    ViewData["Title"] = "Registrar Empresa";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card card-jewel shadow-lg border-0">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <div>
                        <h3 class="mb-0 text-dark fw-bold">
                            <i class="fas fa-plus-circle text-jewel-sapphire me-1"></i> Registrar Nueva Empresa
                        </h3>
                        <p class="text-muted mb-0 small">Registra una nueva empresa cliente y su usuario administrador inicial.</p>
                    </div>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left me-1"></i> Volver
                    </a>
                </div>
                <div class="card-body">
                    <form asp-action="CrearEmpresa" method="post" class="needs-validation">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="row">
                            <!-- Datos de la Empresa -->
                            <div class="col-md-6 border-end pe-md-4">
                                <h5 class="text-jewel-sapphire mb-3 pb-2 border-bottom fw-bold">
                                    <i class="fas fa-industry me-1"></i> Datos de la Empresa
                                </h5>

                                <div class="mb-3">
                                    <label asp-for="Nombre" class="form-label fw-semibold">Nombre de la Empresa *</label>
                                    <input asp-for="Nombre" class="form-control" placeholder="Ej. Aceros del Norte S.A." required id="txtNombreEmpresa" />
                                    <small class="text-muted">El nombre público de la empresa. El identificador de enlace (slug) se generará automáticamente.</small>
                                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                                </div>
                                <input asp-for="Slug" type="hidden" id="txtSlugEmpresa" />

                                <div class="row">
                                    <div class="col-sm-6 mb-3">
                                        <label asp-for="RFC" class="form-label fw-semibold">RFC</label>
                                        <input asp-for="RFC" class="form-control" placeholder="Ej. ANO850101XXX" />
                                        <span asp-validation-for="RFC" class="text-danger small"></span>
                                    </div>
                                    <div class="col-sm-6 mb-3">
                                        <label asp-for="CorreoContacto" class="form-label fw-semibold">Correo de Contacto</label>
                                        <input asp-for="CorreoContacto" type="email" class="form-control" placeholder="contacto@empresa.com" />
                                        <span asp-validation-for="CorreoContacto" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>

                            <!-- Datos del Administrador -->
                            <div class="col-md-6 ps-md-4 mt-4 mt-md-0">
                                <h5 class="text-jewel-sapphire mb-3 pb-2 border-bottom fw-bold">
                                    <i class="fas fa-user me-1"></i> Cuenta Administradora
                                </h5>

                                <div class="mb-3">
                                    <label asp-for="NombreAdmin" class="form-label fw-semibold">Nombre(s) *</label>
                                    <input asp-for="NombreAdmin" class="form-control" placeholder="Ej. Juan" required />
                                    <span asp-validation-for="NombreAdmin" class="text-danger small"></span>
                                </div>

                                <div class="row">
                                    <div class="col-sm-6 mb-3">
                                        <label asp-for="ApellidoAdminP" class="form-label fw-semibold">Primer Apellido *</label>
                                        <input asp-for="ApellidoAdminP" class="form-control" placeholder="Ej. Pérez" required />
                                        <span asp-validation-for="ApellidoAdminP" class="text-danger small"></span>
                                    </div>
                                    <div class="col-sm-6 mb-3">
                                        <label asp-for="ApellidoAdminM" class="form-label fw-semibold">Segundo Apellido</label>
                                        <input asp-for="ApellidoAdminM" class="form-control" placeholder="Ej. Gómez" />
                                        <span asp-validation-for="ApellidoAdminM" class="text-danger small"></span>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="CorreoAdmin" class="form-label fw-semibold">Correo Electrónico *</label>
                                    <input asp-for="CorreoAdmin" type="email" class="form-control" placeholder="admin@empresa.com" required />
                                    <small class="text-muted">Se utilizará para iniciar sesión en la plataforma.</small>
                                    <span asp-validation-for="CorreoAdmin" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="ContrasenaAdmin" class="form-label fw-semibold">Contraseña *</label>
                                    <input asp-for="ContrasenaAdmin" type="password" class="form-control" placeholder="Mínimo 6 caracteres" required />
                                    <span asp-validation-for="ContrasenaAdmin" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4" />

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-secondary px-4">Cancelar</a>
                            <button type="submit" class="btn btn-jewel-primary px-5">Registrar Empresa</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const txtNombre = document.getElementById("txtNombreEmpresa");
            const txtSlug = document.getElementById("txtSlugEmpresa");

            // Generador automático de slug
            txtNombre.addEventListener("input", function () {
                if (txtSlug.dataset.manual !== "true") {
                    txtSlug.value = generateSlug(txtNombre.value);
                }
            });

            txtSlug.addEventListener("input", function () {
                txtSlug.dataset.manual = "true";
                // Limpiar caracteres inválidos
                txtSlug.value = generateSlug(txtSlug.value);
            });

            function generateSlug(text) {
                return text
                    .toString()
                    .toLowerCase()
                    .normalize("NFD") // Separar diacríticos
                    .replace(/[\u0300-\u036f]/g, "") // Eliminar acentos
                    .replace(/\s+/g, "-") // Reemplazar espacios por -
                    .replace(/[^\w\-]+/g, "") // Eliminar caracteres especiales
                    .replace(/\-\-+/g, "-") // Reemplazar múltiples - por uno solo
                    .replace(/^-+/, "") // Eliminar - iniciales
                    .replace(/-+$/, ""); // Eliminar - finales
            }
        });
    </script>
}
