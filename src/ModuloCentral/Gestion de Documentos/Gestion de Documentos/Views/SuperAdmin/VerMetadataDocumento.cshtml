@model Gestion_de_Documentos.Models.Documento
@using System.Security.Claims
@{
    ViewData["Title"] = "Inspección de Metadatos";
    var versionActual = Model.DocumentoVersions.FirstOrDefault();
    var versionActualId = versionActual?.Id ?? 0;
}

@functions {
    public string PrettyPrintJson(string? json)
    {
        if (string.IsNullOrEmpty(json)) return "{}";
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            return System.Text.Json.JsonSerializer.Serialize(doc, new System.Text.Json.JsonSerializerOptions 
            { 
                WriteIndented = true,
                Encoder = System.Text.Encodings.Web.JavaScriptEncoder.UnsafeRelaxedJsonEscaping
            });
        }
        catch
        {
            return json;
        }
    }
}

<div class="container-fluid mt-4">
    <!-- Header -->
    <div class="d-flex align-items-start justify-content-between mb-4 gap-3 flex-wrap">
        <div>
            <h2 class="mb-1 fw-bold text-dark" style="font-size:1.5rem;">
                <i class="fas fa-search text-jewel-sapphire me-2"></i>Inspección de Metadatos: @Model.Titulo
            </h2>
            <span class="text-muted" style="font-size:.85rem;">
                Código Interno: <code class="text-jewel-sapphire">@Model.CodigoInterno</code> &nbsp;·&nbsp; Empresa: <strong>@(Model.IdEmpresaNavigation?.Nombre ?? "Global")</strong>
            </span>
        </div>
        <div class="d-flex gap-2">
            @if (versionActualId > 0)
            {
                <button type="button" id="btnAbrirVisor"
                        class="btn btn-jewel-primary"
                        data-version-id="@versionActualId"
                        data-src="@Url.Action("VerPrevio", "Documento", new { versionId = versionActualId })"
                        data-bs-toggle="modal" data-bs-target="#modalVisorPdf">
                    <i class="fas fa-eye me-2"></i>Visualizar PDF
                </button>
            }
            <a asp-action="Documentos" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i> Volver al Listado
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- Columna Detalle Estructurado (SQL) -->
        <div class="col-lg-4">
            <div class="card card-jewel h-100 shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h6 class="text-muted text-uppercase fw-bold mb-0" style="font-size:.75rem; letter-spacing:.06em;">
                        <i class="fas fa-info-circle me-1 text-jewel-sapphire"></i> Datos Estructurados SQL
                    </h6>
                </div>
                <div class="card-body">
                    <dl class="row mb-0" style="font-size:.9rem; line-height: 2;">
                        <dt class="col-5 text-muted fw-normal">ID SQL</dt>
                        <dd class="col-7"><code>@Model.Id</code></dd>

                        <dt class="col-5 text-muted fw-normal">Código Interno</dt>
                        <dd class="col-7"><code class="text-jewel-sapphire">@Model.CodigoInterno</code></dd>

                        <dt class="col-5 text-muted fw-normal">Título</dt>
                        <dd class="col-7">@Model.Titulo</dd>

                        <dt class="col-5 text-muted fw-normal">Empresa (Tenant)</dt>
                        <dd class="col-7">@(Model.IdEmpresaNavigation?.Nombre ?? "Global")</dd>

                        <dt class="col-5 text-muted fw-normal">Departamento</dt>
                        <dd class="col-7">@(Model.IdDepartamentoNavigation?.Nombre ?? "-")</dd>

                        <dt class="col-5 text-muted fw-normal">Tipo Documento</dt>
                        <dd class="col-7">@(Model.IdTipoDocumentoNavigation?.Nombre ?? "-")</dd>

                        <dt class="col-5 text-muted fw-normal">Estado Actual</dt>
                        <dd class="col-7">
                            @{
                                var badgeClass = Model.EstadoActual switch {
                                    "Borrador"   => "badge-borrador",
                                    "En Revision"=> "badge-revision",
                                    "Vigente"    => "badge-aprobado",
                                    "Rechazado"  => "bg-danger text-white",
                                    "Obsoleto"   => "badge-obsoleto",
                                    _            => "bg-secondary text-white"
                                };
                            }
                            <span class="badge @badgeClass px-2 py-1">@Model.EstadoActual</span>
                        </dd>

                        <dt class="col-5 text-muted fw-normal">Creador</dt>
                        <dd class="col-7">@(Model.IdUsuarioCreacionNavigation?.Nombre) @(Model.IdUsuarioCreacionNavigation?.ApellidoP)</dd>

                        <dt class="col-5 text-muted fw-normal">Fecha Creación</dt>
                        <dd class="col-7">@Model.FechaCreacion?.ToString("dd/MM/yyyy HH:mm")</dd>

                        <dt class="col-5 text-muted fw-normal">Fecha Modificación</dt>
                        <dd class="col-7">@(Model.FechaModificacion?.ToString("dd/MM/yyyy HH:mm") ?? "-")</dd>

                        <dt class="col-5 text-muted fw-normal">Total Versiones</dt>
                        <dd class="col-7"><span class="badge bg-primary">@Model.DocumentoVersions.Count</span></dd>
                    </dl>
                </div>
            </div>
        </div>

        <!-- Columna Metadatos en Crudo (JSON) -->
        <div class="col-lg-8">
            <div class="card card-jewel h-100 shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h6 class="text-muted text-uppercase fw-bold mb-0" style="font-size:.75rem; letter-spacing:.06em;">
                        <i class="fab fa-envira me-1 text-success"></i> Metadatos de Búsqueda (MongoDB)
                    </h6>
                </div>
                <div class="card-body">
                    <p class="text-muted small">JSON de metadatos indexado actualmente en el microservicio NoSQL de MongoDB (colección <code>DocumentosMetadata</code>):</p>
                    @if (ViewBag.RawMongoJson != null)
                    {
                        <pre class="bg-dark text-light p-3 rounded" style="max-height: 450px; overflow-y: auto;"><code class="language-json">@PrettyPrintJson(ViewBag.RawMongoJson as string)</code></pre>
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            <i class="fas fa-exclamation-triangle"></i> El documento no está indexado en MongoDB (se desindexa si está en estado Borrador, en Revisión, Rechazado o Eliminado, o si hay problemas de sincronización).
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Visor PDF (Copiado de Detalle para coherencia de UX) -->
<div class="modal fade" id="modalVisorPdf" tabindex="-1" aria-labelledby="modalVisorLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered" style="max-width:92vw;">
        <div class="modal-content" style="height:90vh;">
            <div class="modal-header" style="background:var(--bg-card); border-bottom:1px solid var(--border);">
                <div class="d-flex align-items-center gap-2">
                    <i class="fas fa-file-pdf text-danger fs-5"></i>
                    <h5 class="modal-title mb-0" id="modalVisorLabel">@Model.Titulo</h5>
                    <code class="text-muted ms-2" style="font-size:.78rem;">@Model.CodigoInterno</code>
                </div>
                <div class="d-flex gap-2 ms-auto me-3">
                    @if (versionActualId > 0)
                    {
                        <a asp-controller="Documento" asp-action="Descargar" asp-route-versionId="@versionActualId"
                           class="btn btn-sm btn-outline-success" title="Descargar PDF">
                            <i class="fas fa-download me-1"></i>Descargar
                        </a>
                    }
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body p-0" style="flex:1; overflow:hidden;">
                <div id="visorLoading" class="d-flex align-items-center justify-content-center h-100"
                     style="background:var(--bg-hover);">
                    <div class="text-center">
                        <div class="spinner-border mb-3" style="color:var(--sapphire); width:3rem; height:3rem;" role="status"></div>
                        <p class="text-muted">Cargando documento...</p>
                    </div>
                </div>
                <iframe id="iframeVisor"
                        src="about:blank"
                        style="width:100%; height:100%; border:none; display:none;"
                        title="Visor de documento PDF">
                </iframe>
            </div>
            <div class="modal-footer" style="background:var(--bg-card); border-top:1px solid var(--border);">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">
                    <i class="fas fa-times me-1"></i>Cerrar Visor
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
    const modal = document.getElementById('modalVisorPdf');
    const iframe = document.getElementById('iframeVisor');
    const loading = document.getElementById('visorLoading');
    const btnAbrir = document.getElementById('btnAbrirVisor');

    if (btnAbrir) {
        btnAbrir.addEventListener('click', function () {
            const src = this.dataset.src;
            loading.classList.remove('d-none');
            loading.classList.add('d-flex');
            iframe.style.display = 'none';
            iframe.src = src;

            // Fallback para navegadores que no disparan el evento 'load' en PDFs
            setTimeout(function() {
                if (!loading.classList.contains('d-none')) {
                    loading.classList.add('d-none');
                    loading.classList.remove('d-flex');
                    iframe.style.display = 'block';
                }
            }, 1500);
        });
    }

    if (iframe) {
        iframe.addEventListener('load', function () {
            if (!loading.classList.contains('d-none')) {
                loading.classList.add('d-none');
                loading.classList.remove('d-flex');
                iframe.style.display = 'block';
            }
        });
    }

    if (modal) {
        modal.addEventListener('hidden.bs.modal', function () {
            iframe.src = 'about:blank';
            loading.classList.remove('d-none');
            loading.classList.add('d-flex');
            iframe.style.display = 'none';
        });
    }
});
</script>
}
