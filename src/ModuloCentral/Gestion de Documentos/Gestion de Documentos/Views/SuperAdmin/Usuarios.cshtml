@model List<Gestion_de_Documentos.Models.Usuario>
@{
    ViewData["Title"] = "Panel Súper Administrador - Usuarios";
}

<div class="container-fluid mt-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold" style="color: var(--jewel-sapphire);">
                <i class="fas fa-user-shield"></i> Panel Súper Administrador
            </h2>
            <p class="text-muted mb-0">Consola de administración global y monitoreo multi-tenant</p>
        </div>
        <a asp-action="CrearEmpresa" class="btn btn-jewel-primary px-4 py-2">
            <i class="fas fa-plus"></i> Registrar Nueva Empresa
        </a>
    </div>

    <!-- Navigation Tabs -->
    <ul class="nav nav-tabs mb-4">
        <li class="nav-item">
            <a class="nav-link text-muted" asp-action="Index"><i class="fas fa-industry me-1"></i> Empresas</a>
        </li>
        <li class="nav-item">
            <a class="nav-link active fw-bold" asp-action="Usuarios"><i class="fas fa-users me-1 text-jewel-sapphire"></i> Usuarios</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-muted" asp-action="Documentos"><i class="fas fa-file-pdf me-1"></i> Documentos</a>
        </li>
    </ul>

    <!-- Filters Card -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form method="get" asp-action="Usuarios" class="row align-items-end g-3">
                <div class="col-md-4">
                    <label for="idEmpresa" class="form-label fw-bold text-secondary">Empresa</label>
                    <select name="idEmpresa" id="idEmpresa" class="form-select">
                        <option value="">-- Todas las Empresas --</option>
                        @foreach (var emp in ViewBag.Empresas)
                        {
                            <!option value="@emp.Id" @(ViewBag.FiltroEmpresa == emp.Id ? "selected" : "")>@emp.Nombre</!option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="idRol" class="form-label fw-bold text-secondary">Rol asignado</label>
                    <select name="idRol" id="idRol" class="form-select">
                        <option value="">-- Todos los Roles --</option>
                        @foreach (var rol in ViewBag.Roles)
                        {
                            <!option value="@rol.Id" @(ViewBag.FiltroRol == rol.Id ? "selected" : "")>@rol.Nombre</!option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="estatus" class="form-label fw-bold text-secondary">Estatus</label>
                    <select name="estatus" id="estatus" class="form-select">
                        <!option value="" @(ViewBag.FiltroEstatus == null ? "selected" : "")>Todos</!option>
                        <!option value="true" @(ViewBag.FiltroEstatus == true ? "selected" : "")>Activos</!option>
                        <!option value="false" @(ViewBag.FiltroEstatus == false ? "selected" : "")>Inactivos</!option>
                    </select>
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-jewel-primary w-100">
                        <i class="fas fa-filter"></i> Filtrar
                    </button>
                    <a asp-action="Usuarios" class="btn btn-outline-secondary w-100" title="Limpiar Filtros">
                        <i class="fas fa-undo"></i>
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Main Content Card -->
    <div class="card card-jewel">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0 text-dark fw-bold">
                <i class="fas fa-users me-1 text-jewel-sapphire"></i> Usuarios del Sistema
            </h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-secondary">
                        <tr>
                            <th class="ps-4">Nombre Completo</th>
                            <th>Correo</th>
                            <th>Empresa</th>
                            <th>Departamento</th>
                            <th>Roles</th>
                            <th class="text-center">Estatus</th>
                            <th class="pe-4">Fecha Creación</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            foreach (var usuario in Model)
                            {
                                var activeRoles = usuario.UsuarioRolIdUsuarioNavigations
                                    .Where(ur => ur.Estatus == true)
                                    .Select(ur => ur.IdRolNavigation.Nombre)
                                    .ToList();
                                    
                                <tr class="@(usuario.Estatus == false ? "table-light opacity-75" : "")">
                                    <td class="ps-4 fw-bold text-dark">
                                        @usuario.Nombre @usuario.ApellidoP @usuario.ApellidoM
                                    </td>
                                    <td>@usuario.Correo</td>
                                    <td>
                                        <span class="badge bg-light text-dark border">
                                            @(usuario.IdEmpresaNavigation?.Nombre ?? "Super Administrador (Global)")
                                        </span>
                                    </td>
                                    <td>@(usuario.IdDepartamentoNavigation?.Nombre ?? "-")</td>
                                    <td>
                                        @if (activeRoles.Any())
                                        {
                                            @foreach (var r in activeRoles)
                                            {
                                                <span class="badge bg-jewel-sapphire text-white me-1">@r</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted small">Sin Rol</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (usuario.Estatus == true)
                                        {
                                            <span class="badge bg-success-light text-success px-2 py-1"><i class="fas fa-check me-1"></i>Activo</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-light text-danger px-2 py-1"><i class="fas fa-ban me-1"></i>Inactivo</span>
                                        }
                                    </td>
                                    <td class="pe-4 text-muted small">
                                        @usuario.FechaCreacion?.ToString("dd/MM/yyyy HH:mm")
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <i class="fas fa-users fa-3x mb-3"></i>
                                    <h5>No se encontraron usuarios con los filtros seleccionados</h5>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
