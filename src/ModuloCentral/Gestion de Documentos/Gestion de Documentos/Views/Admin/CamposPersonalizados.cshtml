@{
    ViewData["Title"] = "Campos Personalizados";
}

<div class="card card-jewel mt-4">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <div>
            <h3 class="mb-0 text-dark">Configuración de Campos Personalizados</h3>
            <p class="text-muted mb-0 small">Define metadatos específicos que tu empresa requiere para clasificar y organizar sus documentos.</p>
        </div>
        <button type="button" class="btn btn-jewel-primary" id="btnAgregarCampo">
            <i class="fas fa-plus"></i> Agregar Campo
        </button>
    </div>
    <div class="card-body">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <form asp-action="GuardarCamposPersonalizados" method="post" id="formCampos">
            <input type="hidden" name="camposJson" id="camposJson" />

            <div class="table-responsive">
                <table class="table table-hover align-middle" id="tablaCampos">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 45%;">Nombre del Campo</th>
                            <th style="width: 25%;">Tipo de Dato</th>
                            <th style="width: 15%;" class="text-center">Requerido</th>
                            <th style="width: 15%;" class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="listaCampos">
                        <!-- Cargar campos existentes -->
                    </tbody>
                </table>
            </div>

            <div id="noCamposMessage" class="text-center py-5 bg-light rounded mb-3 d-none">
                <i class="fas fa-sliders-h fa-3x text-muted mb-3"></i>
                <h5 class="text-secondary">No hay campos personalizados definidos</h5>
                <p class="text-muted mb-0">Agrega campos nuevos para empezar a solicitar metadatos adicionales en tus documentos.</p>
            </div>

            <div class="alert alert-warning mb-4">
                <i class="fas fa-exclamation-triangle"></i> <strong>Importante:</strong> Si modificas o eliminas campos que ya están en uso, los documentos existentes conservarán sus datos históricos tal como se guardaron, pero los nuevos documentos utilizarán la estructura que definas aquí.
            </div>

            <div class="d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                <button type="submit" class="btn btn-jewel-primary px-4">Guardar Configuración</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const rawJson = '@Html.Raw(ViewBag.CamposPersonalizados ?? "[]")';
            const listaCampos = document.getElementById("listaCampos");
            const btnAgregarCampo = document.getElementById("btnAgregarCampo");
            const formCampos = document.getElementById("formCampos");
            const camposJsonInput = document.getElementById("camposJson");
            const noCamposMessage = document.getElementById("noCamposMessage");

            let campos = [];
            try {
                campos = JSON.parse(rawJson);
            } catch (e) {
                console.error("Error parsing camposJson:", e);
                campos = [];
            }

            function checkEmptyState() {
                if (campos.length === 0) {
                    noCamposMessage.classList.remove("d-none");
                    document.getElementById("tablaCampos").classList.add("d-none");
                } else {
                    noCamposMessage.classList.add("d-none");
                    document.getElementById("tablaCampos").classList.remove("d-none");
                }
            }

            function renderCampos() {
                listaCampos.innerHTML = "";
                campos.forEach((campo, index) => {
                    const tr = document.createElement("tr");
                    tr.dataset.index = index;

                    tr.innerHTML = `
                        <td>
                            <input type="text" class="form-control field-nombre" value="${escapeHtml(campo.Nombre)}" placeholder="Ej. Número de Factura" required />
                        </td>
                        <td>
                            <select class="form-select field-tipo">
                                <option value="Texto" ${campo.Tipo === 'Texto' ? 'selected' : ''}>Texto</option>
                                <option value="Numero" ${campo.Tipo === 'Numero' ? 'selected' : ''}>Número</option>
                                <option value="Fecha" ${campo.Tipo === 'Fecha' ? 'selected' : ''}>Fecha</option>
                                <option value="Booleano" ${campo.Tipo === 'Booleano' ? 'selected' : ''}>Booleano (Sí/No)</option>
                            </select>
                        </td>
                        <td class="text-center">
                            <div class="form-check form-switch d-inline-block">
                                <input type="checkbox" class="form-check-input field-requerido" ${campo.Requerido ? 'checked' : ''} />
                            </div>
                        </td>
                        <td class="text-center">
                            <button type="button" class="btn btn-outline-danger btn-sm btn-delete-campo">
                                <i class="fas fa-trash-alt"></i> Eliminar
                            </button>
                        </td>
                    `;

                    // Evento eliminar
                    tr.querySelector(".btn-delete-campo").addEventListener("click", function () {
                        campos.splice(index, 1);
                        renderCampos();
                    });

                    // Evento cambio de Nombre
                    tr.querySelector(".field-nombre").addEventListener("input", function (e) {
                        campos[index].Nombre = e.target.value;
                    });

                    // Evento cambio de Tipo
                    tr.querySelector(".field-tipo").addEventListener("change", function (e) {
                        campos[index].Tipo = e.target.value;
                    });

                    // Evento cambio de Requerido
                    tr.querySelector(".field-requerido").addEventListener("change", function (e) {
                        campos[index].Requerido = e.target.checked;
                    });

                    listaCampos.appendChild(tr);
                });
                checkEmptyState();
            }

            btnAgregarCampo.addEventListener("click", function () {
                campos.push({
                    Nombre: "",
                    Tipo: "Texto",
                    Requerido: false
                });
                renderCampos();
                
                // Enfocar el último input agregado
                setTimeout(() => {
                    const inputs = listaCampos.querySelectorAll(".field-nombre");
                    if (inputs.length > 0) {
                        inputs[inputs.length - 1].focus();
                    }
                }, 50);
            });

            formCampos.addEventListener("submit", function (e) {
                // Filtrar campos vacíos o duplicados antes de enviar
                const nombres = campos.map(c => c.Nombre.trim()).filter(n => n.length > 0);
                const uniqueNombres = [...new Set(nombres)];
                
                if (nombres.length !== campos.length) {
                    e.preventDefault();
                    alert("Todos los campos deben tener un nombre válido.");
                    return;
                }
                
                if (nombres.length !== uniqueNombres.length) {
                    e.preventDefault();
                    alert("No se permiten campos duplicados.");
                    return;
                }

                camposJsonInput.value = JSON.stringify(campos);
            });

            function escapeHtml(str) {
                return str
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;")
                    .replace(/'/g, "&#039;");
            }

            renderCampos();
        });
    </script>
}
