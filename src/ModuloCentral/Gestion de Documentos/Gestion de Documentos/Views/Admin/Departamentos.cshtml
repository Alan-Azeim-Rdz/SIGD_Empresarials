@model List<Departamento>
@{
    ViewData["Title"] = "Gestionar Departamentos";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="fw-bold" style="color: var(--jewel-amethyst);">
                        <i class="fas fa-building"></i> Gestión de Departamentos
                    </h2>
                </div>
                <a asp-action="CrearDepartamento" class="btn btn-jewel-primary">
                    <i class="fas fa-plus"></i> Nuevo Departamento
                </a>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card card-jewel">
                <div class="card-body">
                    @if (Model.Count == 0)
                    {
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i> No hay departamentos registrados.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead style="background-color: var(--jewel-amethyst); color: white;">
                                    <tr>
                                        <th>Nombre</th>
                                        <th>Abreviatura</th>
                                        <th>Fecha Creación</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var dpto in Model)
                                    {
                                        <tr>
                                            <td>@dpto.Nombre</td>
                                            <td><span class="badge bg-light text-dark">@dpto.Abreviatura</span></td>
                                            <td>@dpto.FechaCreacion?.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td>
                                                <a asp-action="EditarDepartamento" asp-route-id="@dpto.Id" class="btn btn-sm btn-warning">
                                                    <i class="fas fa-edit"></i> Editar
                                                </a>
                                                <form asp-action="EliminarDepartamento" method="post" style="display: inline;">
                                                    <input type="hidden" name="id" value="@dpto.Id" />
                                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('¿Estás seguro?');">
                                                        <i class="fas fa-trash"></i> Eliminar
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
