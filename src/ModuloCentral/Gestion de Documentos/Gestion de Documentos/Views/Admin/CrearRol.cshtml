@model Rol
@{
    ViewData["Title"] = "Crear Rol";
}

<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card card-jewel">
                <div class="card-body">
                    <h3 class="fw-bold mb-4" style="color: var(--jewel-amethyst);">
                        <i class="fas fa-plus"></i> Crear Nuevo Rol
                    </h3>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <h6>Por favor, corrige los siguientes errores:</h6>
                            <ul class="mb-0">
                                @foreach (var modelState in ViewData.ModelState.Values)
                                {
                                    @foreach (var error in modelState.Errors)
                                    {
                                        <li>@error.ErrorMessage</li>
                                    }
                                }
                            </ul>
                        </div>
                    }

                    <form asp-action="CrearRol" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Nombre del Rol <span class="text-danger">*</span></label>
                            <input asp-for="Nombre" class="form-control" placeholder="Ej: Gerente, Supervisor" required />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Descripción</label>
                            <textarea asp-for="Descripcion" class="form-control" rows="4" placeholder="Describe el propósito de este rol..."></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Roles" class="btn btn-light">
                                <i class="fas fa-times"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-jewel-primary">
                                <i class="fas fa-save"></i> Guardar Rol
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
