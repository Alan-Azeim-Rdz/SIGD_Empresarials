@using Gestion_de_Documentos.Controllers
@model AsignarPermisosViewModel
@{
    ViewData["Title"] = "Asignar Permisos a Rol";
}

<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-md-12">
            <div class="card card-jewel">
                <div class="card-body">
                    <h3 class="fw-bold mb-2" style="color: var(--jewel-amethyst);">
                        <i class="fas fa-lock"></i> Asignar Permisos
                    </h3>
                    <p class="text-muted mb-4">Rol: <strong>@Model.Rol.Nombre</strong></p>

                    <form asp-action="AsignarPermisosRol" method="post">
                        <input type="hidden" name="idRol" value="@Model.Rol.Id" />

                        <div class="mb-4">
                            <h5 class="fw-bold mb-3">Selecciona los Permisos para este Rol</h5>

                            @if (Model.PermisosDisponibles.Count == 0)
                            {
                                <div class="alert alert-warning">
                                    <i class="fas fa-exclamation-triangle"></i> No hay permisos disponibles. Crea permisos primero.
                                </div>
                            }
                            else
                            {
                                var permisosPorModulo = Model.PermisosDisponibles.GroupBy(p => p.Modulo).OrderBy(g => g.Key);

                                @foreach (var modulo in permisosPorModulo)
                                {
                                    <div class="card mb-3">
                                        <div class="card-header" style="background-color: var(--jewel-amethyst); color: white;">
                                            <h6 class="mb-0"><i class="fas fa-cube"></i> @modulo.Key</h6>
                                        </div>
                                        <div class="card-body">
                                            <div class="row">
                                                @foreach (var permiso in modulo)
                                                {
                                                    var isChecked = Model.PermisosAsignados.Contains(permiso.Id);
                                                    <div class="col-md-6 mb-2">
                                                        <label class="form-check">
                                                            <input type="checkbox" name="permisosSeleccionados" value="@permiso.Id" 
                                                                   class="form-check-input" @(isChecked ? "checked" : "") />
                                                            <span class="form-check-label ms-2">
                                                                <strong>@permiso.Codigo</strong>
                                                                <br />
                                                                <small class="text-muted">@permiso.Descripcion</small>
                                                            </span>
                                                        </label>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>

                        <hr class="my-4" />

                        <div class="row mb-4">
                            <div class="col-12">
                                <h5 class="fw-bold mb-3">Permisos Actualmente Asignados</h5>
                                @if (Model.PermisosAsignados.Count == 0)
                                {
                                    <div class="alert alert-info">
                                        <i class="fas fa-info-circle"></i> No hay permisos asignados todavía.
                                    </div>
                                }
                                else
                                {
                                    <div class="list-group">
                                        @foreach (var idPermiso in Model.PermisosAsignados)
                                        {
                                            var permiso = Model.PermisosDisponibles.FirstOrDefault(p => p.Id == idPermiso);
                                            if (permiso != null)
                                            {
                                                <div class="list-group-item">
                                                    <span class="badge bg-success me-2">@permiso.Modulo</span>
                                                    <code>@permiso.Codigo</code> - @permiso.Descripcion
                                                </div>
                                            }
                                        }
                                    </div>
                                }
                            </div>
                        </div>

                        <hr class="my-4" />

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Roles" class="btn btn-light">
                                <i class="fas fa-arrow-left"></i> Volver
                            </a>
                            <button type="submit" class="btn btn-jewel-primary">
                                <i class="fas fa-save"></i> Guardar Permisos
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
