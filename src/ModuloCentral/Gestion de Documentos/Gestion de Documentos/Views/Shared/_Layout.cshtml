@{
    var _givenName = User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value ?? "";
    var _email     = User.Identity?.Name ?? "";
    var _parts     = _givenName.Split(' ', System.StringSplitOptions.RemoveEmptyEntries);
    var _initials  = _parts.Length >= 2
        ? (_parts[0][0].ToString() + _parts[1][0].ToString()).ToUpper()
        : (_parts.Length == 1 ? _parts[0][0].ToString().ToUpper() : "U");
    var _roleLabel = User.IsInRole("Administrador") ? "Admin"
                   : User.IsInRole("Superior")      ? "Superior"
                   : "Usuario";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Sistema Integral de Gestión Documental Empresarial" />
    <title>@ViewData["Title"] - SIGD Empresarial</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        /* ================================================
           SIGD DARK THEME — Layout v2
           ================================================ */
        :root {
            --bg-main:    #0A0E1A;
            --bg-surface: #141A2A;
            --bg-raised:  #1A2235;
            --border:     #1E2538;
            --accent:     #3B82F6;
            --accent2:    #06B6D4;
            --text:       #F8FAFC;
            --text-muted: #94A3B8;
            --text-dim:   #64748B;
            --success:    #10B981;
            --warning:    #F59E0B;
            --error:      #EF4444;
            --nav-h:      64px;
        }

        /* --- Reset & Base --- */
        *, *::before, *::after { box-sizing: border-box; }
        html { scroll-behavior: smooth; }

        body {
            margin: 0;
            background-color: var(--bg-main);
            color: var(--text);
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
        }

        /* Dot-grid subtle background */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image: radial-gradient(circle, #1E2538 1px, transparent 1px);
            background-size: 32px 32px;
            opacity: 0.3;
            pointer-events: none;
            z-index: 0;
        }

        #sigd-header, .sigd-footer { position: relative; z-index: 1; }
        .sigd-page-wrap { position: relative; }

        /* --- Custom Scrollbar --- */
        ::-webkit-scrollbar              { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track        { background: transparent; }
        ::-webkit-scrollbar-thumb        { background: var(--border); border-radius: 8px; }
        ::-webkit-scrollbar-thumb:hover  { background: var(--accent); }

        /* ================================================
           NAVBAR
           ================================================ */
        #sigd-header { position: sticky; top: 0; z-index: 1000; }

        .navbar.sigd-nav {
            background: rgba(10, 14, 26, 0.9) !important;
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
            padding: 0 24px;
            min-height: var(--nav-h);
        }

        /* Logo */
        .sigd-logo-link {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none !important;
            flex-shrink: 0;
        }
        .sigd-logo-icon  { width: 30px; height: 30px; flex-shrink: 0; }
        .sigd-logo-name  { font-size: 1rem; font-weight: 700; color: var(--text); line-height: 1; }
        .sigd-logo-grad  {
            background: linear-gradient(90deg, var(--accent), var(--accent2));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* Nav links */
        .navbar-nav .nav-link {
            color: var(--text-muted) !important;
            font-size: 0.875rem;
            font-weight: 500;
            padding: 6px 12px !important;
            border-radius: 8px;
            transition: background 200ms ease, color 200ms ease;
            display: flex;
            align-items: center;
            gap: 6px;
            white-space: nowrap;
        }
        .navbar-nav .nav-link:hover {
            color: var(--text) !important;
            background: var(--border);
        }
        .navbar-nav .nav-link.active {
            color: #60A5FA !important;
            background: rgba(59, 130, 246, 0.1);
        }
        .navbar-nav .nav-link i { font-size: 0.78rem; width: 14px; text-align: center; }

        /* Dropdown */
        .dropdown-menu {
            background: var(--bg-surface) !important;
            border: 1px solid var(--border) !important;
            border-radius: 10px !important;
            padding: 6px !important;
            box-shadow: 0 8px 32px rgba(0,0,0,0.5) !important;
            min-width: 200px;
        }

        /* Dropdown animation mejorada */
        .dropdown-menu {
            animation: dropdownFade 150ms ease forwards !important;
            transform-origin: top center;
        }
        @@keyframes dropdownFade {
            from {
                opacity: 0;
                transform: translateY(-6px) scale(0.98);
            }
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }
        .navbar-nav .dropdown-toggle::after {
            transition: transform 150ms ease !important;
        }

        .dropdown-item {
            color: var(--text-muted) !important;
            font-size: 0.875rem;
            border-radius: 6px;
            padding: 8px 12px !important;
            transition: all 180ms ease;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .dropdown-item:hover { color: var(--text) !important; background: var(--border) !important; }
        .dropdown-toggle::after { border-color: var(--text-muted) transparent transparent; transition: transform 200ms; }
        .show > .dropdown-toggle::after { transform: rotate(180deg); }

        /* Hamburger */
        .navbar-toggler {
            border: 1px solid var(--border) !important;
            border-radius: 8px !important;
            padding: 6px 10px !important;
        }
        .navbar-toggler:focus { box-shadow: 0 0 0 2px rgba(59,130,246,0.3) !important; }
        .navbar-toggler-icon {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba(248,250,252,0.85)' stroke-linecap='round' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e") !important;
        }

        /* Mobile collapse panel */
        @@media (max-width: 991px) {
            .navbar-collapse.show,
            .navbar-collapse.collapsing {
                background: var(--bg-surface);
                border-top: 1px solid var(--border);
                margin: 0 -24px;
                padding: 12px 24px 16px;
            }
            .navbar-collapse .navbar-nav .nav-link { padding: 10px 12px !important; }
            .sigd-nav-right {
                flex-direction: column;
                align-items: flex-start !important;
                gap: 6px !important;
                margin-top: 8px;
                padding-top: 8px;
                border-top: 1px solid var(--border);
                width: 100%;
            }
            .sigd-user-card { display: flex !important; }
            .sigd-nav-divider { display: none !important; }
        }

        /* Icon buttons (bell, gear) */
        .sigd-icon-btn {
            width: 34px;
            height: 34px;
            border-radius: 8px;
            border: 1px solid var(--border);
            background: transparent;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 200ms ease;
            text-decoration: none !important;
            position: relative;
            flex-shrink: 0;
        }
        .sigd-icon-btn:hover { background: var(--border); color: var(--text); border-color: var(--accent); }
        .sigd-icon-btn i { font-size: 0.8rem; }
        .sigd-notif-dot {
            position: absolute; top: 6px; right: 6px;
            width: 6px; height: 6px;
            border-radius: 50%; background: var(--error);
        }

        /* Nav divider */
        .sigd-nav-divider { width: 1px; height: 24px; background: var(--border); flex-shrink: 0; }

        /* User card */
        .sigd-user-card {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 5px 8px;
            border-radius: 10px;
            transition: background 200ms;
            cursor: default;
        }
        .sigd-user-card:hover { background: var(--border); }
        .sigd-avatar {
            width: 32px; height: 32px; border-radius: 50%;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            display: flex; align-items: center; justify-content: center;
            font-size: 0.72rem; font-weight: 700; color: #fff; flex-shrink: 0;
        }
        .sigd-user-info   { display: flex; flex-direction: column; line-height: 1.25; }
        .sigd-user-name   { font-size: 0.8rem; font-weight: 600; color: var(--text); }
        .sigd-user-email  { font-size: 0.67rem; color: var(--text-muted); max-width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

        /* Logout button */
        .sigd-logout-btn {
            display: flex; align-items: center; gap: 6px;
            padding: 6px 12px; border-radius: 8px;
            border: 1px solid rgba(239,68,68,0.35);
            background: transparent; color: #FCA5A5;
            font-size: 0.8rem; font-weight: 500;
            text-decoration: none !important;
            transition: all 200ms ease; white-space: nowrap;
        }
        .sigd-logout-btn:hover { background: rgba(239,68,68,0.12); border-color: rgba(239,68,68,0.55); color: #FCA5A5; }
        .sigd-logout-btn i { font-size: 0.75rem; }

        /* Login link (unauthenticated) */
        .sigd-login-btn {
            display: flex; align-items: center; gap: 6px;
            padding: 6px 12px; border-radius: 8px;
            border: 1px solid rgba(59,130,246,0.35);
            background: transparent; color: #93C5FD;
            font-size: 0.8rem; font-weight: 500;
            text-decoration: none !important;
            transition: all 200ms ease;
        }
        .sigd-login-btn:hover { background: rgba(59,130,246,0.1); color: #93C5FD; }

        /* ================================================
           BREADCRUMB
           ================================================ */
        .sigd-breadcrumb-bar {
            border-bottom: 1px solid var(--border);
            padding: 6px 0;
        }
        .sigd-breadcrumb-bar .breadcrumb {
            margin: 0; background: transparent; padding: 0; font-size: 0.75rem;
        }
        .sigd-breadcrumb-bar .breadcrumb-item a {
            color: var(--text-muted); text-decoration: none; transition: color 180ms;
        }
        .sigd-breadcrumb-bar .breadcrumb-item a:hover { color: var(--text); }
        .sigd-breadcrumb-bar .breadcrumb-item.active { color: var(--text-dim); }
        .sigd-breadcrumb-bar .breadcrumb-item + .breadcrumb-item::before { color: var(--border); }

        /* ================================================
           MAIN CONTENT WRAPPER
           ================================================ */
        .sigd-page-wrap {
            max-width: 1400px;
            margin: 0 auto;
            padding: 28px 32px 48px;
        }
        @@media (max-width: 768px) { .sigd-page-wrap { padding: 16px 16px 32px; } }

        /* ================================================
           BOOTSTRAP DARK OVERRIDES
           ================================================ */

        /* Cards */
        .card {
            background: var(--bg-surface) !important;
            border: 1px solid var(--border) !important;
            border-radius: 12px !important;
            color: var(--text) !important;
        }
        .card-header {
            background: var(--bg-raised) !important;
            border-bottom: 1px solid var(--border) !important;
            color: var(--text) !important;
            font-weight: 600;
        }
        .card-footer {
            background: var(--bg-raised) !important;
            border-top: 1px solid var(--border) !important;
            color: var(--text-muted) !important;
        }
        .card-title { color: var(--text) !important; }
        .card-text  { color: var(--text-muted) !important; }

        /* Custom card */
        .sigd-card {
            background: var(--bg-surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 24px;
            color: var(--text);
        }

        /* Tables */
        .table { color: var(--text) !important; border-color: var(--border) !important; }
        .table > thead > tr > th {
            background: var(--bg-raised) !important;
            color: var(--text-muted) !important;
            border-color: var(--border) !important;
            font-size: 0.78rem; font-weight: 600;
            text-transform: uppercase; letter-spacing: 0.04em;
        }
        .table > tbody > tr > td { border-color: var(--border) !important; vertical-align: middle; }
        .table > tbody > tr:hover > td { background: rgba(59,130,246,0.04) !important; }
        .table-striped > tbody > tr:nth-of-type(odd) > * {
            background: rgba(26,34,53,0.5) !important; color: var(--text) !important;
        }
        .table-striped > tbody > tr:nth-of-type(even) > * { background: transparent !important; }
        .table-bordered { border-color: var(--border) !important; }

        /* Inputs & Forms */
        .form-control, .form-select {
            background: var(--bg-main) !important;
            border: 1px solid var(--border) !important;
            color: var(--text) !important;
            border-radius: 8px !important;
            transition: border-color 200ms, box-shadow 200ms;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--accent) !important;
            box-shadow: 0 0 0 3px rgba(59,130,246,0.15) !important;
            background: var(--bg-main) !important;
            color: var(--text) !important;
            outline: none;
        }
        .form-control::placeholder { color: var(--text-dim) !important; }
        .form-select option         { background: var(--bg-surface); color: var(--text); }
        .form-label                 { color: var(--text-muted) !important; font-size: 0.875rem; font-weight: 500; }
        .form-text                  { color: var(--text-dim) !important; }
        .form-check-input           { background-color: var(--bg-main) !important; border-color: var(--border) !important; }
        .form-check-input:checked   { background-color: var(--accent) !important; border-color: var(--accent) !important; }
        .form-check-label           { color: var(--text-muted) !important; }
        textarea.form-control       { resize: vertical; }
        .input-group-text           { background: var(--bg-raised) !important; border: 1px solid var(--border) !important; color: var(--text-muted) !important; }

        /* Buttons */
        .btn { font-weight: 500; font-size: 0.875rem; border-radius: 8px !important; transition: all 200ms ease; }

        .btn-primary {
            background: linear-gradient(90deg, var(--accent), var(--accent2)) !important;
            border: none !important; color: #fff !important;
        }
        .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 4px 15px rgba(59,130,246,0.35) !important; filter: brightness(1.08); }

        .btn-success {
            background: var(--success) !important; border-color: var(--success) !important; color: #fff !important;
        }
        .btn-success:hover { background: #0da271 !important; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(16,185,129,0.3) !important; }

        .btn-danger {
            background: var(--error) !important; border-color: var(--error) !important; color: #fff !important;
        }
        .btn-danger:hover { background: #dc2626 !important; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(239,68,68,0.3) !important; }

        .btn-warning {
            background: var(--warning) !important; border-color: var(--warning) !important; color: #0A0E1A !important;
        }
        .btn-warning:hover { filter: brightness(1.1); transform: translateY(-1px); }

        .btn-secondary {
            background: var(--bg-raised) !important; border-color: var(--border) !important; color: var(--text-muted) !important;
        }
        .btn-secondary:hover { background: var(--border) !important; color: var(--text) !important; }

        .btn-light {
            background: var(--bg-raised) !important; border-color: var(--border) !important; color: var(--text) !important;
        }

        .btn-outline-primary  { border-color: var(--accent) !important; color: var(--accent) !important; background: transparent !important; }
        .btn-outline-primary:hover  { background: rgba(59,130,246,0.1) !important; }

        .btn-outline-secondary { border-color: var(--border) !important; color: var(--text-muted) !important; background: transparent !important; }
        .btn-outline-secondary:hover { background: var(--border) !important; color: var(--text) !important; }

        .btn-outline-success  { border-color: var(--success) !important; color: #6EE7B7 !important; background: transparent !important; }
        .btn-outline-success:hover  { background: rgba(16,185,129,0.1) !important; }

        .btn-outline-danger   { border-color: rgba(239,68,68,0.4) !important; color: #FCA5A5 !important; background: transparent !important; }
        .btn-outline-danger:hover   { background: rgba(239,68,68,0.12) !important; }

        .btn-outline-warning  { border-color: rgba(245,158,11,0.4) !important; color: #FCD34D !important; background: transparent !important; }
        .btn-outline-info     { border-color: rgba(6,182,212,0.4) !important; color: #67E8F9 !important; background: transparent !important; }

        /* Legacy site.css custom button classes */
        .btn-jewel-primary {
            background: linear-gradient(90deg, var(--accent), var(--accent2)) !important;
            border: none !important; color: #fff !important;
        }
        .btn-jewel-primary:hover { transform: translateY(-1px); box-shadow: 0 4px 15px rgba(59,130,246,0.35) !important; }
        .btn-outline-jewel {
            background: transparent !important;
            border: 1px solid var(--accent) !important; color: var(--accent) !important;
        }
        .btn-outline-jewel:hover { background: rgba(59,130,246,0.1) !important; }

        /* Badges */
        .badge { font-size: 0.7rem; font-weight: 500; padding: 4px 8px; border-radius: 6px; }
        .badge.bg-success   { background: rgba(16,185,129,0.15) !important; color: #6EE7B7 !important; }
        .badge.bg-warning   { background: rgba(245,158,11,0.15) !important; color: #FCD34D !important; }
        .badge.bg-danger    { background: rgba(239,68,68,0.15) !important;  color: #FCA5A5 !important; }
        .badge.bg-primary   { background: rgba(59,130,246,0.15) !important; color: #93C5FD !important; }
        .badge.bg-secondary { background: rgba(100,116,139,0.2) !important; color: var(--text-muted) !important; }
        .badge.bg-info      { background: rgba(6,182,212,0.15) !important;  color: #67E8F9 !important; }
        .badge.bg-light     { background: var(--bg-raised) !important; color: var(--text-muted) !important; }
        /* Custom status badges */
        .badge-aprobado { background: rgba(16,185,129,0.15) !important; color: #6EE7B7 !important; }
        .badge-revision { background: rgba(245,158,11,0.15) !important; color: #FCD34D !important; }
        .badge-borrador { background: rgba(59,130,246,0.15) !important; color: #93C5FD !important; }
        .badge-obsoleto { background: rgba(239,68,68,0.15) !important;  color: #FCA5A5 !important; }

        /* Alerts */
        .alert          { border-radius: 10px !important; border-width: 0 0 0 3px !important; }
        .alert-success  { background: rgba(16,185,129,0.1) !important;  border-color: var(--success) !important; color: #6EE7B7 !important; }
        .alert-danger   { background: rgba(239,68,68,0.1) !important;   border-color: var(--error) !important;   color: #FCA5A5 !important; }
        .alert-warning  { background: rgba(245,158,11,0.1) !important;  border-color: var(--warning) !important; color: #FCD34D !important; }
        .alert-info     { background: rgba(6,182,212,0.1) !important;   border-color: var(--accent2) !important; color: #67E8F9 !important; }
        .alert-primary  { background: rgba(59,130,246,0.1) !important;  border-color: var(--accent) !important;  color: #93C5FD !important; }
        .alert-secondary{ background: rgba(100,116,139,0.1) !important; border-color: var(--border) !important;  color: var(--text-muted) !important; }

        /* Modals */
        .modal-content  { background: var(--bg-surface) !important; border: 1px solid var(--border) !important; border-radius: 14px !important; color: var(--text) !important; }
        .modal-header   { background: var(--bg-raised) !important; border-bottom: 1px solid var(--border) !important; border-radius: 14px 14px 0 0 !important; }
        .modal-footer   { background: var(--bg-raised) !important; border-top: 1px solid var(--border) !important; border-radius: 0 0 14px 14px !important; }
        .modal-title    { color: var(--text) !important; font-size: 0.95rem; font-weight: 600; }
        .modal-body     { color: var(--text-muted); }
        .btn-close      { filter: invert(1) !important; opacity: 0.5; }
        .btn-close:hover{ opacity: 1; }
        .modal-backdrop.show { opacity: 0.65 !important; background-color: #000 !important; }

        /* Pagination */
        .page-link  { background: var(--bg-surface) !important; border-color: var(--border) !important; color: var(--text-muted) !important; }
        .page-link:hover { background: var(--border) !important; color: var(--text) !important; }
        .page-item.active .page-link { background: var(--accent) !important; border-color: var(--accent) !important; color: #fff !important; }
        .page-item.disabled .page-link { background: var(--bg-raised) !important; color: var(--text-dim) !important; }

        /* List groups */
        .list-group-item { background: var(--bg-surface) !important; border-color: var(--border) !important; color: var(--text) !important; }
        .list-group-item:hover { background: var(--bg-raised) !important; }
        .list-group-item.active { background: rgba(59,130,246,0.1) !important; border-color: rgba(59,130,246,0.3) !important; color: #60A5FA !important; }

        /* Progress */
        .progress     { background: var(--border) !important; border-radius: 8px; }
        .progress-bar { background: linear-gradient(90deg, var(--accent), var(--accent2)); }

        /* Misc */
        hr               { border-color: var(--border) !important; opacity: 1; }
        h1, h2, h3, h4, h5, h6 { color: var(--text); }
        .text-muted      { color: var(--text-muted) !important; }
        .bg-light        { background: var(--bg-surface) !important; }
        .bg-white        { background: var(--bg-raised) !important; }
        .border          { border-color: var(--border) !important; }
        .border-bottom   { border-color: var(--border) !important; }
        .spinner-border  { color: var(--accent) !important; }

        /* Focus visible */
        :focus-visible { outline: 2px solid rgba(59,130,246,0.5); outline-offset: 2px; }

        /* ================================================
           FOOTER
           ================================================ */
        .sigd-footer {
            border-top: 1px solid var(--border);
            padding: 20px 32px;
            position: relative; z-index: 1;
        }
        .sigd-footer-inner {
            max-width: 1400px; margin: 0 auto;
            display: flex; justify-content: space-between; align-items: center; gap: 16px;
        }
        .sigd-footer-copy  { font-size: 0.74rem; color: var(--text-dim); }
        .sigd-footer-links { display: flex; gap: 16px; }
        .sigd-footer-links a { font-size: 0.74rem; color: var(--text-dim); text-decoration: none; transition: color 180ms; }
        .sigd-footer-links a:hover { color: var(--text-muted); }
        @@media (max-width: 640px) { .sigd-footer-inner { flex-direction: column; text-align: center; } }

        /* ================================================
           UTILITY CLASSES
           ================================================ */
        .text-accent  { color: var(--accent) !important; }
        .text-accent2 { color: var(--accent2) !important; }
        .bg-surface   { background: var(--bg-surface) !important; }
        .bg-raised    { background: var(--bg-raised) !important; }
        .border-sigd  { border-color: var(--border) !important; }
        .rounded-sigd { border-radius: 10px !important; }
        .sigd-sep     { width: 1px; height: 20px; background: var(--border); display: inline-block; }
    </style>
</head>
<body>
    <header id="sigd-header">
        <!-- ── NAVBAR ───────────────────────────────── -->
        <nav class="navbar navbar-expand-lg sigd-nav" id="main-nav">
            <div class="container-fluid px-0">

                <!-- Logo -->
                <a class="sigd-logo-link" asp-area="" asp-controller="Home" asp-action="Index">
                    <svg class="sigd-logo-icon" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <defs>
                            <linearGradient id="nav-lg" x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
                                <stop offset="0%" stop-color="#3B82F6"/>
                                <stop offset="100%" stop-color="#06B6D4"/>
                            </linearGradient>
                        </defs>
                        <path d="M16 2L4 7v8c0 7.18 5.16 13.9 12 15.5C22.84 28.9 28 22.18 28 15V7L16 2z"
                              fill="url(#nav-lg)" opacity="0.18"/>
                        <path d="M16 2L4 7v8c0 7.18 5.16 13.9 12 15.5C22.84 28.9 28 22.18 28 15V7L16 2z"
                              stroke="url(#nav-lg)" stroke-width="1.5" fill="none"/>
                        <path d="M11 16l3.5 3.5L21 12" stroke="url(#nav-lg)" stroke-width="1.5"
                              stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span class="sigd-logo-name">SIGD <span class="sigd-logo-grad">Empresarial</span></span>
                </a>

                <!-- Hamburger (mobile only) -->
                <button class="navbar-toggler d-lg-none ms-auto me-0" type="button"
                        data-bs-toggle="collapse" data-bs-target="#navbarContent"
                        aria-controls="navbarContent" aria-expanded="false" aria-label="Abrir menú">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Collapsible area -->
                <div class="collapse navbar-collapse" id="navbarContent">

                    <!-- Center nav links -->
                    <ul class="navbar-nav mx-auto gap-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home"></i>Inicio
                            </a>
                        </li>

                        @if (User.Identity!.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Documento" asp-action="Index">
                                    <i class="fas fa-file-alt"></i>Mis Documentos
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Busqueda" asp-action="Global">
                                    <i class="fas fa-search"></i>Buscador Global
                                </a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="ddModulos" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-network-wired"></i>Módulos Planta
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="ddModulos">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Modulos" asp-action="Dashboard">
                                            <i class="fas fa-chart-bar" style="color: var(--warning);"></i>Dashboard Reportes
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Modulos" asp-action="Portal">
                                            <i class="fas fa-book" style="color: var(--success);"></i>Portal de Normativas
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }

                        @if (User.IsInRole("Administrador") || User.IsInRole("Superior"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Flujo" asp-action="Pendientes">
                                    <i class="fas fa-bell" style="color: var(--warning);"></i>Aprobaciones
                                </a>
                            </li>
                        }
                        @if (User.IsInRole("Super Administrador"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="SuperAdmin" asp-action="Index">
                                    <i class="fas fa-user-shield me-1"></i>Consola SúperAdmin
                                </a>
                            </li>
                        }
                        @if (User.IsInRole("Administrador"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Index">
                                    <i class="fas fa-cogs me-1"></i>Administración
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Auth" asp-action="Registro">
                                    <i class="fas fa-user-plus" style="color: var(--warning);"></i>Crear Usuario
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Auth" asp-action="Usuarios">
                                    <i class="fas fa-users" style="color: var(--accent2);"></i>Ver Usuarios
                                </a>
                            </li>
                        }
                    </ul>

                    <!-- Right section -->
                    <div class="sigd-nav-right d-flex align-items-center gap-2">
                        @if (User.Identity!.IsAuthenticated)
                        {
                            <div class="sigd-nav-divider d-none d-lg-block"></div>

                            <!-- User card (desktop) -->
                            <div class="sigd-user-card d-none d-lg-flex">
                                <div class="sigd-avatar">@_initials</div>
                                <div class="sigd-user-info">
                                    <span class="sigd-user-name">@_givenName</span>
                                    <span class="sigd-user-email">@_email</span>
                                </div>
                            </div>

                            <!-- Logout -->
                            <a class="sigd-logout-btn" asp-controller="Auth" asp-action="Logout">
                                <i class="fas fa-sign-out-alt"></i>Salir
                            </a>
                        }
                        else
                        {
                            <a class="sigd-login-btn" asp-controller="Auth" asp-action="Login">
                                <i class="fas fa-sign-in-alt"></i>Iniciar Sesión
                            </a>
                        }
                    </div>

                </div>
            </div>
        </nav>

        <!-- ── BREADCRUMB ────────────────────────────── -->
        <div class="sigd-breadcrumb-bar">
            <div class="sigd-page-wrap" style="padding-top: 0; padding-bottom: 0;">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item">
                            <a asp-controller="Home" asp-action="Index" class="text-decoration-none">
                                <i class="fas fa-home me-1"></i>SIGD
                            </a>
                        </li>
                        @if (ViewData["Title"]?.ToString() != "Inicio")
                        {
                            <li class="breadcrumb-item active">@ViewData["Title"]</li>
                        }
                    </ol>
                </nav>
            </div>
        </div>
    </header>

    <!-- ── MAIN CONTENT ─────────────────────────────── -->
    <div class="sigd-page-wrap">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <!-- ── FOOTER ───────────────────────────────────── -->
    <footer class="sigd-footer">
        <div class="sigd-footer-inner">
            <span class="sigd-footer-copy">v2.0.1 &nbsp;·&nbsp; &copy; 2026 SIGD Empresarial</span>
            <div class="sigd-footer-links">
                <a href="#">Documentación</a>
                <a href="#">API</a>
                <a href="#">Soporte</a>
            </div>
        </div>
    </footer>

    <!-- ── SCRIPTS ──────────────────────────────────── -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        (function () {
            const currentHost = window.location.hostname;
            const resolvedUrls = {
                csharp: localStorage.getItem('cfg_url_csharp') || window.location.origin,
                php:    localStorage.getItem('cfg_url_php')    || `http://${currentHost}:8000`,
                node:   localStorage.getItem('cfg_url_node')   || `http://${currentHost}:3000`
            };

            document.addEventListener('DOMContentLoaded', function () {

                // Highlight active nav link
                const path = window.location.pathname.toLowerCase();
                document.querySelectorAll('#main-nav .nav-link').forEach(el => {
                    const href = el.getAttribute('href') || '';
                    if (href !== '#' && href !== '/' && path.startsWith(href.toLowerCase())) {
                        el.classList.add('active');
                    }
                });

                // Modal conexiones — pre-fill inputs
                const inputCSharp = document.getElementById('cfg_csharp');
                const inputPHP    = document.getElementById('cfg_php');
                const inputNode   = document.getElementById('cfg_node');
                if (inputCSharp) inputCSharp.value = resolvedUrls.csharp;
                if (inputPHP)    inputPHP.value    = resolvedUrls.php;
                if (inputNode)   inputNode.value   = resolvedUrls.node;

                const btnGuardar = document.getElementById('btnGuardarConexiones');
                if (btnGuardar) {
                    btnGuardar.addEventListener('click', () => {
                        localStorage.setItem('cfg_url_csharp', inputCSharp.value.trim());
                        localStorage.setItem('cfg_url_php',    inputPHP.value.trim());
                        localStorage.setItem('cfg_url_node',   inputNode.value.trim());
                        location.reload();
                    });
                }

                const btnReset = document.getElementById('btnResetConexiones');
                if (btnReset) {
                    btnReset.addEventListener('click', () => {
                        localStorage.removeItem('cfg_url_csharp');
                        localStorage.removeItem('cfg_url_php');
                        localStorage.removeItem('cfg_url_node');
                        location.reload();
                    });
                }
            });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
    document.addEventListener('DOMContentLoaded', function () {
        var modalEl = document.getElementById('modalConexiones');
        if (modalEl) {
            modalEl.addEventListener('hidden.bs.modal', function () {
                document.body.classList.remove('modal-open');
                var backdrops = document.querySelectorAll('.modal-backdrop');
                backdrops.forEach(function(b) { b.remove(); });
                document.body.style.removeProperty('overflow');
                document.body.style.removeProperty('padding-right');
            });
        }
    });
    </script>
</body>
</html>
